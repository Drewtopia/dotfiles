# NOTE: when multiple patterns match a file, the LAST one wins.
# So: general/catchall rules go FIRST, specific overrides go LAST.

# Default: auto-detect
* text=auto

# Chezmoi templates default to LF (most of them are sh/toml/yaml/json).
# Specific template types below override this.
*.tmpl text eol=lf

# Shell scripts must be LF (WSL/Linux/macOS)
*.sh text eol=lf
*.sh.tmpl text eol=lf
*.zsh text eol=lf

# Config files — LF for cross-platform consistency
*.toml text eol=lf
*.toml.tmpl text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Markdown
*.md text eol=lf

# PowerShell — CRLF (overrides the *.tmpl default above)
*.ps1 text eol=crlf
*.ps1.tmpl text eol=crlf

# Windows-specific files
*.wslconfig text eol=crlf
