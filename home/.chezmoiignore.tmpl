!.oh-my-zsh/plugins
{{ range .zshPlugins }}
!.oh-my-zsh/plugins/{{ . }}
!.oh-my-zsh/plugins/{{ . }}/**
{{- end }}
.oh-my-zsh/cache/**
.oh-my-zsh/plugins/**
.oh-my-zsh/templates/**
.oh-my-zsh/custom/themes/powerlevel10k/**/*.zwc

# Ignore non-macOS files.
{{ if ne .chezmoi.os "darwin" }}
.chezmoiscripts/darwin/**
.config/aerospace
.config/homebrew
.config/karabiner
.config/leaderkey
.hammerspoon
.config/iterm
.Brewfile
Library
{{ end }}

# Ignore kanata on Linux only (works on macOS and Windows)
{{ if eq .chezmoi.os "linux" }}
.config/kanata
{{ end }}

# Ignore non-Linux files.
{{ if ne .chezmoi.os "linux" }}
.chezmoiscripts/linux/**
.hushlogin
.local/bin/nvim
.local/share/fonts
{{ end }}

# Bash login files are WSL-only (other Linux uses distro defaults; Mac uses zsh)
{{ if not .is_wsl }}
.bashrc
.profile
{{ end }}

# wezterm is a host GUI emulator that reaches into WSL via the WSL domain; it
# never runs inside the guest, so don't litter ~/.wezterm.lua there. Native
# Linux desktops can still run it, so this is WSL-only, not all Linux.
{{ if .is_wsl }}
.wezterm.lua
{{ end }}

# Ignore non-Windows files.
{{ if ne .chezmoi.os "windows" }}
.chezmoiscripts/windows/**
.chezmoiscripts/**/*.ps1
.chezmoiscripts/**/*.ps1.tmpl
.config/windows_terminal
.wslconfig
Documents
AppData
{{ else }}
# Windows: Ignore Unix shell scripts
.chezmoiscripts/**/*.sh
.chezmoiscripts/**/*.sh.tmpl
# Windows: Ignore Unix/Linux-specific files
**/.DS_Store
.bash_aliases
.config/1Password
.config/1Password/**
.config/cheatsheets
.config/cheatsheets/**
.config/fzf-tab-completion
.config/fzf-tab-completion/**
.config/ghostty
.config/git/cookies
.config/path-management.sh
.config/shell
.config/shell/**
.config/shell-loader.sh
# tmux: drop everything (e.g. a synced plugins/ dir) but keep the two
# conf files — psmux reads tmux.conf via $PSMUX_CONFIG_FILE on Windows.
.config/tmux/**
!.config/tmux/tmux.conf
!.config/tmux/tmux.reset.conf
.config/zsh
.config/zsh/**
.inputrc
.local/share/zinit
.local/share/zinit/**
.oh-my-zsh
.oh-my-zsh/**
.p10k.zsh
.tmux.conf
.zprofile
.zshrc
{{ end }}

README.md

# Temp files
.chezmoidata/

# Neovim
**/autoload/
**/autoload/**/*
**/plugged/
**/plugged/**/*
**/yankring_history*.txt

# Lazyvim
.config/nvim/lazy-lock.json


# Claude
{{- if and (eq .chezmoi.os "windows") .work }}
# Work-Windows: chezmoi never touches ~/.claude. bootstrap-work-claude renders
# dot_claude/ directly into the relocated CLAUDE_CONFIG_DIR.
.claude
.claude/**
{{- else }}
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/agents/
!.claude/hooks/
!.claude/skills/
{{-   if eq .chezmoi.os "windows" }}
# Personal Windows: chezmoi-managed symlink (requires Developer Mode).
!.claude/rules
{{-   else }}
# Mac/Linux: chezmoi-managed symlinks at .claude/memory and .claude/rules.
!.claude/memory
!.claude/rules
{{-   end }}
!.claude/mcp.json
!.claude/CLAUDE.md
{{- end }}

{{ if .relocated -}}
# Relocated: .local/bin is a junction to tools_root — chezmoi can't manage junctions
.local/bin
{{- end }}
