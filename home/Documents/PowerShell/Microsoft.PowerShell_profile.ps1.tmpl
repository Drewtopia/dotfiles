{{- if and (eq .chezmoi.os "windows") .dev_computer -}}
# PowerShell Profile - Dev Tools (sourced from OneDrive profile)

# --- PATH helpers ---

# Add mise shims to PATH if mise is installed
$miseShimPath = "$env:USERPROFILE\AppData\Local\mise\shims"
if ((Test-Path $miseShimPath) -and $env:PATH -notlike "*$miseShimPath*") {
    $env:PATH = "$miseShimPath;$env:PATH"
}

# Activate mise. Most mise-managed tools on Windows install to
# .local\share\mise\installs\<name>\... paths that only `mise activate` adds to
# PATH — the shims directory isn't populated by default here. Must run BEFORE
# the tool inits below (carapace/atuin/tv/etc), or those inits can't find their
# binaries and silently skip.
if (Get-Command mise -ErrorAction SilentlyContinue) {
    (&mise activate pwsh) | Out-String | Invoke-Expression
}

# pnpm global packages setup
$pnpmHome = "$env:USERPROFILE\.local\share\pnpm"
if ((Test-Path $pnpmHome) -and $env:PATH -notlike "*$pnpmHome*") {
    $env:PATH = "$pnpmHome;$env:PATH"
}

# WinLibs (gcc/g++) — winget installs it but doesn't wire PATH, and Windows
# Terminal caches PATH at host start, so new tabs may miss the USER PATH entry.
# Probe the well-known winget package location and inject if present.
$winLibsBin = "$env:LOCALAPPDATA\Microsoft\WinGet\Packages\BrechtSanders.WinLibs.POSIX.UCRT_Microsoft.Winget.Source_8wekyb3d8bbwe\mingw64\bin"
if ((Test-Path "$winLibsBin\gcc.exe") -and $env:PATH -notlike "*$winLibsBin*") {
    $env:PATH = "$env:PATH;$winLibsBin"
}

# Ensure PSReadLine is loaded before tool inits that bind keys (atuin, tv, carapace).
# pwsh auto-loads PSReadLine lazily for the REPL, but that can happen AFTER profile
# execution — which makes atuin/tv init bail with "Atuin requires the PSReadLine module".
Import-Module PSReadLine -ErrorAction SilentlyContinue

# Carapace - multi-shell completion engine
if (Get-Command carapace -ErrorAction SilentlyContinue) {
    $env:CARAPACE_BRIDGES = 'zsh,fish,bash,inshellisense'
    Set-PSReadLineOption -Colors @{ "Selection" = "`e[7m" }
    Set-PSReadlineKeyHandler -Key Tab -Function MenuComplete
    carapace _carapace | Out-String | Invoke-Expression
}

# Zoxide - smarter cd command
if (Get-Command zoxide -ErrorAction SilentlyContinue) {
    (& zoxide init powershell) | Out-String | Invoke-Expression
}

# Television - smart fuzzy finder with context-aware channels.
# Init runs BEFORE atuin: tv's pwsh init unconditionally binds Ctrl+R to
# Invoke-TvShellHistory (ignoring shell_integration.keybindings in its config),
# so atuin's Ctrl+R handler needs to bind last to win. Ctrl+T still goes to tv.
if (Get-Command tv -ErrorAction SilentlyContinue) {
    (& tv init power-shell) | Out-String | Invoke-Expression
}

# Atuin - shell history. Must init AFTER tv so Ctrl+R binding wins.
if (Get-Command atuin -ErrorAction SilentlyContinue) {
    (& atuin init powershell) | Out-String | Invoke-Expression
}

# pay-respects - command correction (thefuck replacement)
if (Get-Command pay-respects -ErrorAction SilentlyContinue) {
    pay-respects pwsh --alias f | Out-String | Invoke-Expression
}

# fnox - secrets manager with shell integration.
# Requires fnox >= 1.21.0 for pwsh support.
if (Get-Command fnox -ErrorAction SilentlyContinue) {
    (&fnox activate pwsh) | Out-String | Invoke-Expression
}

# PowerToys CommandNotFound module
if (Get-Module -ListAvailable -Name Microsoft.WinGet.CommandNotFound) {
    Import-Module -Name Microsoft.WinGet.CommandNotFound
}

# Kanata toggles - manual on/off (used primarily on work machines where
# auto-start is intentionally disabled to avoid Jump Desktop double-remap).
# Personal machines also get these as a convenience alongside the
# scheduled task.
if (Get-Command kanata -ErrorAction SilentlyContinue) {
    $script:KanataConfigPath = "$env:USERPROFILE\.config\kanata\kanata.kbd"

    function kanata-status {
        $running = Get-Process kanata -ErrorAction SilentlyContinue
        $task = Get-ScheduledTask -TaskName Kanata -ErrorAction SilentlyContinue
        if ($running) {
            Write-Host "kanata: RUNNING (pid $($running.Id -join ','))" -ForegroundColor Green
        } else {
            Write-Host "kanata: not running" -ForegroundColor Yellow
        }
        if ($task) {
            Write-Host "scheduled task: registered ($($task.State))" -ForegroundColor Cyan
        } else {
            Write-Host "scheduled task: not registered (manual-toggle mode)" -ForegroundColor Cyan
        }
    }

    function kanata-on {
        if (Get-Process kanata -ErrorAction SilentlyContinue) {
            Write-Host "kanata already running" -ForegroundColor Yellow
            return
        }
        $task = Get-ScheduledTask -TaskName Kanata -ErrorAction SilentlyContinue
        if ($task) {
            Start-ScheduledTask -TaskName Kanata
            Write-Host "kanata started (via scheduled task)" -ForegroundColor Green
        } else {
            if (-not (Test-Path $script:KanataConfigPath)) {
                Write-Host "kanata config missing at $script:KanataConfigPath" -ForegroundColor Red
                return
            }
            Start-Process -FilePath kanata -ArgumentList "--cfg `"$script:KanataConfigPath`"" -WindowStyle Hidden
            Write-Host "kanata started (direct process)" -ForegroundColor Green
        }
    }

    function kanata-off {
        $task = Get-ScheduledTask -TaskName Kanata -ErrorAction SilentlyContinue
        if ($task -and $task.State -eq 'Running') {
            Stop-ScheduledTask -TaskName Kanata
        }
        $running = Get-Process kanata -ErrorAction SilentlyContinue
        if ($running) {
            $running | Stop-Process -Force -ErrorAction SilentlyContinue
            Write-Host "kanata stopped" -ForegroundColor Green
        } else {
            Write-Host "kanata not running" -ForegroundColor Yellow
        }
    }
}
{{- end }}
