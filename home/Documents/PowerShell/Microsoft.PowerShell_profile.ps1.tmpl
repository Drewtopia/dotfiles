{{- if and (eq .chezmoi.os "windows") .dev_computer -}}
# PowerShell Profile - Dev Tools (sourced from OneDrive profile)

# --- Init-script caching infrastructure ---

$script:PwshInitCacheDir = "$env:LOCALAPPDATA\pwsh-init-cache"

function Invoke-CachedInit {
    param(
        [string]$Tool,
        [string]$VersionCommand,
        [scriptblock]$InitCommand
    )

    if (-not (Test-Path $script:PwshInitCacheDir)) {
        New-Item -ItemType Directory -Path $script:PwshInitCacheDir -Force | Out-Null
    }

    $cacheFile = Join-Path $script:PwshInitCacheDir "$Tool.ps1"
    $versionFile = Join-Path $script:PwshInitCacheDir "$Tool.version"

    $currentVersion = & ([scriptblock]::Create($VersionCommand)) 2>$null | Out-String
    $currentVersion = $currentVersion.Trim()

    $cachedVersion = if (Test-Path $versionFile) { (Get-Content $versionFile -Raw).Trim() } else { '' }

    if ($currentVersion -eq $cachedVersion -and (Test-Path $cacheFile)) {
        . $cacheFile
    } else {
        $initOutput = & $InitCommand | Out-String
        $initOutput | Set-Content -Path $cacheFile -Force
        $currentVersion | Set-Content -Path $versionFile -Force
        Invoke-Expression $initOutput
    }
}

function Clear-PwshInitCache {
    if (Test-Path $script:PwshInitCacheDir) {
        Remove-Item -Path $script:PwshInitCacheDir -Recurse -Force
        Write-Host "Cleared pwsh init cache. Restart shell to regenerate."
    } else {
        Write-Host "No cache directory found."
    }
}

# --- PATH helpers ---

# Add mise shims to PATH if mise is installed
$miseShimPath = "$env:USERPROFILE\AppData\Local\mise\shims"
if ((Test-Path $miseShimPath) -and $env:PATH -notlike "*$miseShimPath*") {
    $env:PATH = "$miseShimPath;$env:PATH"
}

# Activate mise synchronously. Most mise-managed tools on Windows install to
# .local\share\mise\installs\<name>\... paths that only `mise activate` adds to
# PATH — the shims directory isn't populated by default here. Without this running
# BEFORE the tool inits below (carapace/atuin/tv/etc), those inits can't find
# their binaries and silently skip. Cached inline (not via Invoke-CachedInit)
# because `mise activate pwsh` defines `function mise { ... }`, which needs to
# land in global scope — dot-sourcing from inside a function would trap it.
if (Get-Command mise -ErrorAction SilentlyContinue) {
    if (-not (Test-Path $script:PwshInitCacheDir)) {
        New-Item -ItemType Directory -Path $script:PwshInitCacheDir -Force | Out-Null
    }
    $miseCacheFile = Join-Path $script:PwshInitCacheDir 'mise.ps1'
    $miseVersionFile = Join-Path $script:PwshInitCacheDir 'mise.version'
    $miseCurrentVersion = (mise --version 2>$null | Out-String).Trim()
    $miseCachedVersion = if (Test-Path $miseVersionFile) { (Get-Content $miseVersionFile -Raw).Trim() } else { '' }
    if ($miseCurrentVersion -ne $miseCachedVersion -or -not (Test-Path $miseCacheFile)) {
        (mise activate pwsh | Out-String) | Set-Content -Path $miseCacheFile -Force
        $miseCurrentVersion | Set-Content -Path $miseVersionFile -Force
    }
    . $miseCacheFile
}

# pnpm global packages setup
$pnpmHome = "$env:USERPROFILE\.local\share\pnpm"
if ((Test-Path $pnpmHome) -and $env:PATH -notlike "*$pnpmHome*") {
    $env:PATH = "$pnpmHome;$env:PATH"
}

# Ensure PSReadLine is loaded before tool inits that bind keys (atuin, tv, carapace).
# pwsh auto-loads PSReadLine lazily for the REPL, but that can happen AFTER profile
# execution — which makes atuin/tv init bail with "Atuin requires the PSReadLine module".
Import-Module PSReadLine -ErrorAction SilentlyContinue

# Carapace - multi-shell completion engine
if (Get-Command carapace -ErrorAction SilentlyContinue) {
    $env:CARAPACE_BRIDGES = 'zsh,fish,bash,inshellisense'
    Set-PSReadLineOption -Colors @{ "Selection" = "`e[7m" }
    Set-PSReadlineKeyHandler -Key Tab -Function MenuComplete
    Invoke-CachedInit -Tool 'carapace' -VersionCommand 'carapace --version' -InitCommand { carapace _carapace }
}

# Zoxide - smarter cd command
if (Get-Command zoxide -ErrorAction SilentlyContinue) {
    Invoke-CachedInit -Tool 'zoxide' -VersionCommand 'zoxide --version' -InitCommand { zoxide init powershell }
}

# Atuin - shell history
if (Get-Command atuin -ErrorAction SilentlyContinue) {
    Invoke-CachedInit -Tool 'atuin' -VersionCommand 'atuin --version' -InitCommand { atuin init powershell }
}

# pay-respects - command correction (thefuck replacement)
if (Get-Command pay-respects -ErrorAction SilentlyContinue) {
    pay-respects pwsh --alias f | Out-String | Invoke-Expression
}

# Television - smart fuzzy finder with context-aware channels
if (Get-Command tv -ErrorAction SilentlyContinue) {
    Invoke-CachedInit -Tool 'television' -VersionCommand 'tv --version' -InitCommand { tv init power-shell }
}

# PowerToys CommandNotFound module
if (Get-Module -ListAvailable -Name Microsoft.WinGet.CommandNotFound) {
    Import-Module -Name Microsoft.WinGet.CommandNotFound
}
{{- end }}
