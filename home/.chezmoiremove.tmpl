.tmux.config

# Old fzf configs (replaced by eval "$(fzf --zsh)")
.fzf.zsh
.fzf.bash

# Prevent stale ~/.gitconfig from shadowing chezmoi-managed
# ~/.config/git/config (git prefers ~/.gitconfig when both exist).
# Git-for-Windows installer can re-create this on reinstall.
.gitconfig

# Old custom.paths.sh (deleted from chezmoi source)
.config/shell/paths/custom.paths.sh

{{- if eq .chezmoi.os "linux" }}
# Old chezmoi-external binaries now handled by mise
.local/bin/age
.local/bin/age-keygen
.local/bin/croc
.local/bin/eza
.local/bin/gdu
.local/bin/glow
.local/bin/golangci-lint
.local/bin/jless
.local/bin/uv
.local/bin/delta
.local/bin/lazygit
.local/bin/yt-dlp
.local/bin/jj
.local/bin/carapace
{{- end }}

# .atuin already removed — don't re-prompt

# Old PATH management files (consolidated into shell/000-paths.sh + .zshenv)
.config/path-management.sh
.config/shell/paths

# Old unnumbered shell configs (replaced by numbered equivalents)
.config/shell/060-common_aliases.sh
.config/shell/cheatsheets.sh
.config/shell/dev-tools.sh
.config/shell/mise.sh
.config/shell/shell-tools.sh
.config/shell/system-tools.sh

# prd-to-issues replaced by to-issues (mattpocock renamed Apr 2026)
.claude/skills/prd-to-issues

# mattpocock/skills v1.0.0 (Jun 2026 "design skills" refactor) removed/renamed these.
# Remove both the ~/.claude/skills symlink AND the ~/.agents/skills payload that
# `npx skills` leaves behind (chezmoi doesn't manage the .agents store, so dropping
# a skill from skills.yaml otherwise orphans the payload on every machine).
.claude/skills/write-a-skill
.claude/skills/diagnose
.claude/skills/zoom-out
.agents/skills/write-a-skill
.agents/skills/diagnose
.agents/skills/zoom-out

# mattpocock/skills v1.1.0 (Jul 2026): to-issues + to-prd unified upstream
# into to-spec + to-tickets. Same dual-path removal as above.
.claude/skills/to-issues
.claude/skills/to-prd
.agents/skills/to-issues
.agents/skills/to-prd
