{{- $name := "" -}}
{{- $dev_computer := false -}}

{{/* set up 1Password vaults */}}
{{- $opVault := "" -}}

{{/* boolean feature tags */}}
{{- $ephemeral := false -}}{{/* true if this machine is ephemeral, e.g. a cloud or VM instance */}}
{{- $work := false -}}{{/* true if this machine is a work machine */}}
{{- $is_wsl := false -}}{{/* true if this machine is a WSL machine */}}
{{- $personal := false -}}{{/* true if this machine should have personal secrets */}}
{{- "" -}}

{{- $osID := .chezmoi.os -}}
{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
{{-   $osID = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{/* detect GitHub codespaces, VSCode remote containers, Docker containers, Multipass VMs, and Vagrant boxes */}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS_IPC") (eq .chezmoi.username "root" "ubuntu" "vagrant" "vscode") -}}
{{-   $ephemeral = true -}}
{{- end -}}

{{- if eq .chezmoi.os "linux" -}}
{{-   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
{{-   $is_wsl = true -}}
{{-   end -}}
{{- end -}}

{{/* work around unreliable hostname on darwin */}}
{{- $hostname := .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $hostname = output "scutil" "--get" "LocalHostName" | trim | lower -}}
{{- end -}}

{{/* Windows: Check for known personal hostnames, otherwise prompt or default to ephemeral */}}
{{- if eq .chezmoi.os "windows" -}}
{{-   $personalWindowsHosts := list "andrews-desktop" "drew-pd" -}}
{{-   if has ($hostname | lower) $personalWindowsHosts -}}
{{-     $personal = true -}}
{{-     $opVault = "Private" -}}
{{-   else if or (stdinIsATTY) (hasKey . "ephemeral") -}}
{{-     $ephemeral = promptBoolOnce . "ephemeral" "Is this an ephemeral machine (no secrets)?" -}}
{{-     if not $ephemeral -}}
{{-       $personal = promptBoolOnce . "personal" "Is this your personal machine?" -}}
{{-       if $personal -}}
{{-         $opVault = "Private" -}}
{{-       else -}}
{{-         $work = true -}}
{{-         $opVault = "Employee" -}}
{{-       end -}}
{{-     end -}}
{{-   else -}}
{{-     $ephemeral = true -}}
{{-   end -}}
{{- end -}}

{{- if and (not $ephemeral) (ne .chezmoi.os "windows") -}}
{{-   if eq $hostname "andrews-macbook-pro" -}}
{{-     $personal = true -}}
{{-     $opVault = "Private" -}}
{{-   else if or (stdinIsATTY) (hasKey . "ephemeral") -}}
{{-     $ephemeral = promptBoolOnce . "ephemeral" "Is this an ephemeral machine (no secrets)?" -}}
{{-     if not $ephemeral -}}
{{-       $personal = promptBoolOnce . "personal" "Is this your personal machine?" -}}
{{-       if $personal -}}
{{-         $opVault = "Private" -}}
{{-       else -}}
{{-         $work = true -}}
{{-         $opVault = "Employee" -}}
{{-       end -}}
{{-     end -}}
{{-   else -}}
{{-     $ephemeral = true -}}
{{-   end -}}
{{- end -}}

{{- if not $ephemeral -}}
{{-   $dev_computer = promptBoolOnce . "dev_computer" "Install dev tools on this machine?" -}}
{{- end -}}

{{- $email := "" -}}
{{- if $opVault -}}
{{-   if lookPath "op" -}}
{{/*   op installed: pull identity from the vault (preferred path) */}}
{{-     $name = onepasswordRead (printf "op://%s/Identity/handle" $opVault) | trim -}}
{{-     $email = onepasswordRead (printf "op://%s/Identity/email" $opVault) | trim -}}
{{-   else -}}
{{/*   Fresh-machine fallback: op not yet installed. Prompt and store in the
       local chezmoi.toml (never committed to git). After this apply, the
       run_onchange_before_install-op script installs op, so subsequent
       inits could use the vault path — but the cached prompt value sticks
       because of promptStringOnce. Manually delete the entry to switch. */}}
{{-     $name = promptStringOnce . "name" "Your full name (op CLI not detected; stored locally only)" -}}
{{-     $email = promptStringOnce . "email" "Your email" -}}
{{-   end -}}
{{- end -}}

{{/* Relocatable dev tools root — on work Windows, prompt for a whitelisted
     top-level folder name so tool binaries live under an allowed path.
     Leave blank to keep everything under $HOME as normal. */}}
{{- $tools_root := .chezmoi.homeDir -}}
{{- if and $work (eq .chezmoi.os "windows") -}}
{{-   $dev_folder := promptStringOnce . "dev_folder" "Top-level folder name for relocated dev tools (resolves to C:/<this>/<username>; leave blank for $HOME)" -}}
{{-   if $dev_folder -}}
{{-     $tools_root = printf "C:/%s/%s" $dev_folder (last (splitList "\\" (.chezmoi.username | lower))) -}}
{{-   end -}}
{{- end -}}
{{/* relocated: this machine relocates dev tools out of $HOME into a
     whitelisted tools_root. Only ever true on work Windows (set above), so it
     implies both work and windows. The single named condition every relocation
     script and template gates on. */}}
{{- $relocated := ne $tools_root .chezmoi.homeDir -}}
{{- $dev_root := printf "%s/dev" $tools_root -}}

{{/* mise data dir — always use .mise for easy access (see mise.jdx.dev/how-i-use-mise) */}}
{{- $mise_dir := printf "%s/.mise" $tools_root -}}
{{- $claude_dir := printf "%s/.claude" $tools_root -}}
{{- $codex_dir := printf "%s/.codex" $tools_root -}}
{{- $pnpm_home := printf "%s/.local/share/pnpm" $tools_root -}}
{{- $vscode_ext_dir := printf "%s/.vscode/extensions" $tools_root -}}
{{- $vscode_global_storage_dir := printf "%s/.vscode/globalStorage" $tools_root -}}

# Make mise-managed tools visible to chezmoi templates (lookPath, etc.)
[env]
{{ if eq .chezmoi.os "windows" -}}
{{-   $miseShims := printf "%s/shims" $mise_dir | replace "/" "\\" -}}
{{-   $cleanPathParts := list -}}
{{/*  Drop EVERY mise shim dir (relocated `<root>\.mise\shims` and legacy
      `%LOCALAPPDATA%\mise\shims`); the canonical one is prepended below. Two
      mise shim dirs on PATH defeat mise's re-entry guard and fork-bomb
      (jdx/mise dual-dir shim recursion).
      CANONICAL RULE PARALLEL: this build-time (Go template) dedup is the twin
      of the PowerShell Get-NormalizedPath fork-bomb guard in the
      windows-relocation partial (run_onchange_before_05 + the pwsh profile).
      Two runtimes, same rule; they cannot share code. Keep them in sync. */}}
{{-   range $part := splitList ";" (env "PATH") -}}
{{-     $normalized := $part | replace "/" "\\" | trimSuffix "\\" -}}
{{-     $lower := $normalized | lower -}}
{{-     if and $normalized (not (or (hasSuffix "\\.mise\\shims" $lower) (hasSuffix "\\mise\\shims" $lower))) -}}
{{-       $cleanPathParts = append $cleanPathParts $normalized -}}
{{-     end -}}
{{-   end -}}
    PATH = '{{ $miseShims }};{{ join ";" $cleanPathParts }}'
{{- else }}
    PATH = "{{ $mise_dir }}/shims:{{ env "PATH" }}"
{{- end }}

[data]
  ephemeral = {{ $ephemeral }}
  name = {{ $name | quote }}
  email = {{ $email | quote }}
  work = {{ $work }}
  relocated = {{ $relocated }}
  is_wsl = {{ $is_wsl }}
  dev_computer = {{ $dev_computer }}
  hostname = {{ $hostname | quote }}
  personal = {{ $personal }}
  osid = {{ $osID | quote }}
  opVault = {{ $opVault | quote }}
  zshPlugins = [
      "git",
      "tmux",
      {{- if eq .chezmoi.os "darwin" }}
        "brew",
      {{- end}}
  ]
  [data.directories]
    tools_root = "{{ $tools_root }}"
    dev_root = "{{ $dev_root }}"
    claude_dir = "{{ $claude_dir }}"
    codex_dir = "{{ $codex_dir }}"
    pnpm_home = "{{ $pnpm_home }}"
    vscode_ext_dir = "{{ $vscode_ext_dir }}"
    vscode_global_storage_dir = "{{ $vscode_global_storage_dir }}"
    mise_dir = "{{ $mise_dir }}"
    repos_dir = "{{ $tools_root }}/repos"
    ssh_keys_dir = "{{ .chezmoi.homeDir }}/.ssh_keys"
    user_bin_dir = "{{ $tools_root }}/bin"
    xdg_cache_dir = "{{ $tools_root }}/.cache"
    xdg_config_dir = "{{ .chezmoi.homeDir }}/.config"
    xdg_data_dir = "{{ .chezmoi.homeDir }}/.local/share"
    xdg_state_dir = "{{ .chezmoi.homeDir }}/.local/state"

[github]
    refreshPeriod = "12h"

[git]
    autoCommit = true
    commitMessageTemplate = {{ printf "%q" "{{ promptString `Commit message` }}" }}

{{- if and $dev_computer (ne .chezmoi.os "windows") }}
[diff]
    pager = "delta"
{{- end }}

[merge]
    command = "nvim"
    args = [
        "-d",
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Source }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]

{{ if eq .chezmoi.os "windows" -}}
# cd uses pwsh (interactive only, available after 00-install-pwsh runs)
[cd]
    command = "pwsh"

# interpreter uses powershell.exe (built-in 5.1) so scripts can bootstrap
# pwsh before it exists on a fresh machine.
# -NonInteractive: the child must not run as an interactive shell. Without
# it, a Ctrl-C'd long-running script leaks its raw `PS>` prompt into the
# parent terminal and corrupts PSReadLine input state (scrambled keystrokes).
[interpreters.ps1]
    command = "powershell.exe"
    args = ["-NoLogo", "-NoProfile", "-NonInteractive"]
{{- end }}
