{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "EDITOR": "nvim",
    "GIT_EDITOR": "nvim --wait"{{- if eq .chezmoi.os "windows" }},
    "CLAUDE_CODE_GIT_BASH_PATH": "C:\\Program Files\\Git\\bin\\bash.exe",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "ECC_GATEGUARD": "off",
    "ECC_DISABLED_HOOKS": "pre:config-protection,stop:format-typecheck,post:quality-gate,post:edit:console-warn,stop:check-console-log,stop:evaluate-session,stop:cost-tracker,stop:desktop-notify,post:session-activity-tracker,stop:session-end,session:start,pre:compact"{{- end }}
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(pnpm run :*)",
      "Bash(cargo :*)",
      "Bash(go :*)",
      "Bash(git :*)",
      "Bash(git worktree :*)",
      "Bash(gh :*)",
      "Bash(jj :*)",
      "Bash(docker :*)",
      "Bash(kubectl :*)",
      "Bash(terraform :*)",
      "Bash(rg :*)",
      "Bash(ripgrep :*)",
      "Bash(fd :*)",
      "Bash(fzf :*)",
      "Bash(bat :*)",
      "Bash(exa :*)",
      "Bash(eza :*)",
      "Bash(delta :*)",
      "Bash(zoxide :*)",
      "Bash(duf :*)",
      "Bash(htop :*)",
      "Bash(btop :*)",
      "Bash(jq :*)",
      "Bash(yq :*)",
      "Bash(hexyl :*)",
      "Bash(mkdir -p /tmp/claude-scratch*)",
      "Bash(touch /tmp/claude-*)",
      "Bash(cat /tmp/claude-*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(dd if=/dev/zero of=/dev/*)",
      "Bash(mkfs.:*)",
      "Bash(> /dev/sda*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/block-secrets.js\"'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/pre-bash-dispatcher.js\"'"
          },
          {
            "type": "command",
            "command": "bash -c '\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/hooks/git-commit-precheck.sh'"
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/block-secrets.js\"'"
          },
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/warn-worktree-convention.js\"'"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/warn-edit-on-protected.js\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/post-edit-format.js\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/stop-end-of-turn.js\"'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/notify.js\"'"
          }
        ]
      }
    ],
    "SessionStart": [
{{- if ne .chezmoi.os "windows" }}
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "find \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\" -name '*.sh' ! -executable -exec chmod +x {} + 2>/dev/null; find \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\" -name '*.py' ! -executable -exec chmod +x {} + 2>/dev/null; true"
          }
        ]
      },
{{- end }}
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/session-start-git-status.js\"'",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun x -y ccstatusline@latest",
    "padding": 0
  },
  {{- /* enabledPlugins: merge profile-gated plugin tables from claude.toml */ -}}
  {{- $enabled := dict -}}
  {{- range $k, $v := .plugins.always -}}{{- $_ := set $enabled $k $v -}}{{- end -}}
  {{- if .personal -}}{{- range $k, $v := .plugins.personal -}}{{- $_ := set $enabled $k $v -}}{{- end -}}{{- end -}}
  {{- if .dev_computer -}}{{- range $k, $v := .plugins.dev_computer -}}{{- $_ := set $enabled $k $v -}}{{- end -}}{{- end }}
  "enabledPlugins": {{ $enabled | mustToPrettyJson | indent 2 | trim }},
  {{- /* extraKnownMarketplaces: render all registered marketplaces from claude.toml */ -}}
  {{- $marketplaces := dict -}}
  {{- range $name, $repo := .marketplaces -}}
    {{- $_ := set $marketplaces $name (dict "source" (dict "source" "github" "repo" $repo)) -}}
  {{- end }}
  "extraKnownMarketplaces": {{ $marketplaces | mustToPrettyJson | indent 2 | trim }},
  "autoUpdatesChannel": "latest",
  "verbose": true,
  "preferredNotifChannel": "terminal_bell",
  "agentPushNotifEnabled": false
}
