#!/usr/bin/env bash
{{/*
  chezmoi modify_ script for ~/.claude/settings.json.

  Why modify_ and not a plain template: Claude Code rewrites this file at
  runtime (plugin enable/disable, marketplace adds, survey/tips state) and
  plugins inject their own hook entries. A plain overwrite template fights
  that and shows a "changed since chezmoi last wrote it" prompt every apply.

  This treats the chezmoi-managed settings as a FLOOR merged over the live
  runtime file:
    - runtime wins on scalar conflicts (Claude's toggles survive);
    - objects merge in the runtime file's key order (byte-clean vs Claude's
      serializer -> no formatting drift);
    - arrays union (managed entries enforced, runtime/plugin additions kept);
    - hook commands enforced only if absent (never duplicated / double-fired).
  Net: managed keys stay enforced, Claude's runtime state survives, drift gone.

  The managed JSON below is the former settings.json.tmpl body verbatim; it is
  rendered per-machine, then deep-merged over the on-disk file via jq.
*/}}
set -euo pipefail
{{ if eq .chezmoi.os "windows" }}
# chezmoi runs this via Git Bash on Windows; scoop shims (jq) aren't on PATH.
export PATH="$HOME/scoop/shims:$PATH"
{{ end }}
managed=$(cat <<'CHEZMOI_SETTINGS_EOF'
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "EDITOR": "nvim",
    "GIT_EDITOR": "nvim --wait",
    "ECC_GATEGUARD": "off"{{- if eq .chezmoi.os "windows" }},
    "CLAUDE_CODE_GIT_BASH_PATH": "C:\\Program Files\\Git\\bin\\bash.exe",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTO_BACKGROUND_TASKS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "ECC_DISABLED_HOOKS": "pre:config-protection,stop:format-typecheck,post:quality-gate,post:edit:console-warn,stop:check-console-log,stop:evaluate-session,stop:cost-tracker,stop:desktop-notify,post:session-activity-tracker,stop:session-end,session:start,pre:compact"{{- end }}
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(pnpm run :*)",
      "Bash(cargo :*)",
      "Bash(go :*)",
      "Bash(git :*)",
      "Bash(wt :*)",
      "Bash(gh :*)",
      "Bash(docker :*)",
      "Bash(kubectl :*)",
      "Bash(terraform :*)",
      "Bash(rg :*)",
      "Bash(fd :*)",
      "Bash(fzf :*)",
      "Bash(bat :*)",
      "Bash(eza :*)",
      "Bash(delta :*)",
      "Bash(zoxide :*)",
      "Bash(btop :*)",
      "Bash(jq :*)",
      "Bash(yq :*)",
      "Bash(mkdir -p /tmp/claude-scratch*)",
      "Bash(touch /tmp/claude-*)",
      "Bash(cat /tmp/claude-*)"
    ],
    "deny": [
      "Bash(> /dev/sda*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/block-secrets.js\"'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/pre-bash-dispatcher.js\"'"
          },
          {
            "type": "command",
            "command": "bash -c '\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/hooks/git-commit-precheck.sh'"
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/block-secrets.js\"'"
          },
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/warn-worktree-convention.js\"'"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/warn-edit-on-protected.js\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/post-edit-format.js\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/stop-end-of-turn.js\"'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/notify.js\"'"
          }
        ]
      }
    ],
    "SessionStart": [
{{- if ne .chezmoi.os "windows" }}
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "find \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\" -name '*.sh' ! -executable -exec chmod +x {} + 2>/dev/null; find \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\" -name '*.py' ! -executable -exec chmod +x {} + 2>/dev/null; true"
          }
        ]
      },
{{- end }}
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/session-start-git-status.js\"'",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun x -y ccstatusline@latest",
    "padding": 0
  },
  {{- /* enabledPlugins: merge profile-gated plugin tables from claude.toml */ -}}
  {{- $enabled := dict -}}
  {{- range $k, $v := .plugins.always -}}{{- $_ := set $enabled $k $v -}}{{- end -}}
  {{- if .personal -}}{{- range $k, $v := .plugins.personal -}}{{- $_ := set $enabled $k $v -}}{{- end -}}{{- end -}}
  {{- if .dev_computer -}}{{- range $k, $v := .plugins.dev_computer -}}{{- $_ := set $enabled $k $v -}}{{- end -}}{{- end }}
  "enabledPlugins": {{ $enabled | mustToPrettyJson | indent 2 | trim }},
  {{- /* extraKnownMarketplaces: render all registered marketplaces from claude.toml */ -}}
  {{- $marketplaces := dict -}}
  {{- range $name, $repo := .marketplaces -}}
    {{- $_ := set $marketplaces $name (dict "source" (dict "source" "github" "repo" $repo)) -}}
  {{- end }}
  "extraKnownMarketplaces": {{ $marketplaces | mustToPrettyJson | indent 2 | trim }},
  "autoUpdatesChannel": "latest",
  "verbose": true,
  "preferredNotifChannel": "terminal_bell",
  "agentPushNotifEnabled": false
}
CHEZMOI_SETTINGS_EOF
)

existing=$(cat)
[ -n "${existing//[[:space:]]/}" ] || existing='{}'

printf '%s' "$existing" | jq --argjson m "$managed" '
  # dm(a;b): merge managed (a) as a floor under runtime (b). b (runtime) wins.
  def dm(a;b):
    if (a|type)=="object" and (b|type)=="object" then
      reduce (((b|keys_unsorted)+(a|keys_unsorted))
              | reduce .[] as $x ([]; if any(.[];.==$x) then . else .+[$x] end))[] as $k ({};
        .[$k] = (if   (b|has($k)) and (a|has($k)) then dm(a[$k]; b[$k])
                 elif (b|has($k))                 then b[$k]
                 else                                  a[$k] end))
    elif (a|type)=="array" and (b|type)=="array" then
      # hook-event arrays (objects with matcher+hooks): keep runtime verbatim,
      # append a managed hook only if its command string is absent anywhere.
      if ((b+a)|length>0) and ((b+a)|all(type=="object" and has("matcher") and has("hooks"))) then
        ([b[]|.hooks[].command]) as $bc
        | b + ( [ a[]
                  | .hooks = [ .hooks[] | select(.command as $c | ($bc|index($c))==null) ]
                  | select(.hooks|length>0) ] )
      else
        b + (a - b)
      end
    else b end;
  # bind runtime input to $e first: jq args are call-by-name filters, so passing
  # "." rebinds b to the reduce accumulator mid-merge and drops runtime-only keys.
  . as $e | dm($m; $e)
' | tr -d '\r'
