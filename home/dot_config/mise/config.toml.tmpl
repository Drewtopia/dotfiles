{{ if .dev_computer -}}
# Global mise configuration — single source of truth for dev tools
# OS package managers (brew/scoop/apt) only handle system deps + GUI apps

[tools]
# Language runtimes
node = "latest"
pnpm = "latest"
deno = "latest"
bun = "latest"
python = "latest"
uv = "latest"
go = "latest"
rust = "latest"
# zig doubles as a C/C++ compiler via `zig cc` — used as CC below so tools
# like nvim-treesitter (main branch) can compile parsers without a system gcc.
zig = "latest"

# mise ecosystem
usage = "latest"
fnox = "latest"
# neovim via mise core backend (tracks GitHub releases directly, upgrades on `mise upgrade`)
neovim = "latest"
# chezmoi via mise so upgrades don't collide with a running chezmoi.exe the
# way winget's reinstall-style upgrade does (lock error on the live binary).
chezmoi = "latest"

# Cross-platform CLI tools (aqua backend — checksum-verified)
"aqua:sharkdp/bat" = "latest"
"aqua:sharkdp/fd" = "latest"
"aqua:BurntSushi/ripgrep" = "latest"
"aqua:dandavison/delta" = "latest"
"aqua:jesseduffield/lazygit" = "latest"
"aqua:max-sixty/worktrunk" = "latest"
"aqua:cli/cli" = "latest"
"aqua:charmbracelet/glow" = "latest"
"aqua:jqlang/jq" = "latest"
"aqua:FiloSottile/age" = "latest"
"aqua:dundee/gdu" = "latest"
"aqua:golangci/golangci-lint" = "latest"
"aqua:gitleaks/gitleaks" = "latest"
"aqua:topgrade-rs/topgrade" = "latest"
"aqua:mikefarah/yq" = "latest"
"aqua:alexpasmantier/television" = "latest"
"aqua:biomejs/biome" = "latest"
# moon: monorepo task runner. The global launcher proxies to each project's
# pinned @moonrepo/cli version. Installed via mise so it lands in the whitelisted
# dir and builds run on Windows without falling back to WSL.
"aqua:moonrepo/moon" = "latest"
# gk: GitKraken CLI. Not in aqua-registry yet, fall back to github backend.
# Installs under MISE_DATA_DIR (whitelisted on locked-down work machines),
# unlike GitLens's bundled gk.exe at %APPDATA%\Code\User\globalStorage\...
"github:gitkraken/gk-cli" = "latest"

# npm-backed CLI tools (pure JS, cross-platform)
"npm:defuddle" = "latest"

# pipx-backed CLI tools (pure Python, cross-platform)
# commit-check: policy engine for Conventional Commits + Conventional Branch +
# push safety. Drives the git/Claude push gate (see dot_claude/hooks).
"pipx:commit-check" = "latest"

# Cross-platform shell tools
"aqua:junegunn/fzf" = "latest"
"aqua:ajeetdsouza/zoxide" = "latest"
atuin = "latest"
"aqua:carapace-sh/carapace-bin" = "latest"

# Platform-specific backends (cargo needs MSVC on Windows)
{{ if eq .chezmoi.os "windows" -}}
"github:iffse/pay-respects" = "latest"
"github:eza-community/eza" = "latest"
{{ else -}}
"cargo:pay-respects" = "latest"
"cargo:tokei" = "latest"
eza = "latest"
{{ end -}}

{{ if ne .chezmoi.os "windows" -}}
# Unix-only (no Windows binary)
"aqua:PaulJuliusMartinez/jless" = "latest"
# qmd — local search engine for markdown (BM25 + vector + LLM rerank).
# Native deps (node-llama-cpp) build cleanly on macOS/Linux; deferring Windows.
"npm:@tobilu/qmd" = "latest"
{{ end -}}

{{ if .personal -}}
# Personal-only tools
yt-dlp = "latest"
"aqua:schollz/croc" = "latest"
{{ end -}}

[settings]
experimental = true
idiomatic_version_file_enable_tools = ['node', 'pnpm']

# Persist computed env to disk so cold mise spawns skip the full tool walk.
env_cache = true
env_cache_ttl = '1h'

# Disable command-not-found hook. The pwsh profile has 7+ `Get-Command -EA SilentlyContinue`
# probes; with this off, a missed probe no longer spawns `mise hook-not-found`. Safe on
# Unix too — explicit `mise install` / `mise x` still auto-install.
not_found_auto_install = false

# Avoid opportunistic GitHub version checks during normal use; refresh on `mise upgrade`.
prefer_offline = true
fetch_remote_versions_cache = '24h'

{{ if eq .chezmoi.os "windows" -}}
# Windows-only: process spawn is ~10x more expensive than fork on Unix, and
# `mise activate pwsh` installs prompt/chpwd hooks that oh-my-posh re-fires on every
# redraw. chpwd_only restricts hook-env to actual `cd`s; cache_ttl reuses stat results.
# Tradeoff: editing a .mise.toml in the current dir no longer triggers a re-resolve
# until the next `cd`. Acceptable on Windows; not worth it on Unix where the flood
# doesn't manifest and per-prompt refresh is essentially free.
hook_env.chpwd_only = true
hook_env.cache_ttl = '5s'
{{ end -}}

[settings.node]
gpg_verify = false

{{- end }}
