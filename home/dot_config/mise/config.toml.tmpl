{{ if .dev_computer -}}
# Global mise configuration — single source of truth for dev tools
# OS package managers (brew/scoop/apt) only handle system deps + GUI apps

[tools]
# Language runtimes (core backend)
node = "latest"
pnpm = "latest"
deno = "latest"
bun = "latest"
python = "3.12"
uv = "latest"
go = "latest"
rust = "latest"

# mise ecosystem tools
usage = "latest"
fnox = "latest"
"cargo:pay-respects" = "latest"

# CLI tools — aqua backend (checksum-verified, cross-platform)
"aqua:sharkdp/bat" = "latest"
"aqua:sharkdp/fd" = "latest"
"aqua:BurntSushi/ripgrep" = "latest"
"aqua:dandavison/delta" = "latest"
"aqua:jesseduffield/lazygit" = "latest"
"aqua:jj-vcs/jj" = "latest"
"aqua:cli/cli" = "latest"
"aqua:charmbracelet/glow" = "latest"
"aqua:jqlang/jq" = "latest"
"aqua:FiloSottile/age" = "latest"
"aqua:dundee/gdu" = "latest"
"aqua:golangci/golangci-lint" = "latest"

# eza — not in aqua, github backend grabs wrong asset, use core registry
eza = "latest"

{{ if ne .chezmoi.os "windows" -}}
# Unix-only (no Windows binary available)
"aqua:PaulJuliusMartinez/jless" = "latest"
{{ end -}}

{{ if .personal -}}
# Personal-only tools
# yt-dlp — github backend names binary yt-dlp_macos, use core registry
yt-dlp = "latest"
"aqua:schollz/croc" = "latest"
{{ end -}}

[settings]
experimental = true
activate_aggressive = true
idiomatic_version_file_enable_tools = ['node', 'pnpm']

[settings.node]
gpg_verify = false

{{- end }}
