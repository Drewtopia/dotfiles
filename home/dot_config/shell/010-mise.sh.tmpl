{{ if .dev_computer -}}
# mise - Modern runtime version manager
# Handles: node, pnpm, deno, bun, uv, python, go, etc.

# Consolidate mise directories under ~/.mise (see mise.jdx.dev/how-i-use-mise)
export MISE_DATA_DIR="{{ .directories.mise_dir }}"

if command -v mise >/dev/null 2>&1; then
    # Activate mise - this handles PATH and completions for all tools
    eval "$(mise activate zsh)"

    # Enable mise completions
    if [[ -n ${ZSH_NAME} ]]; then
        eval "$(mise completion zsh)"
    elif [[ -n ${BASH} ]]; then
        eval "$(mise completion bash)"
    fi
fi

# pnpm now managed by mise - no manual PATH setup needed
# However, pnpm global packages need PNPM_HOME for global installs.
# pnpm 10 put binaries directly in $PNPM_HOME; pnpm 11+ uses $PNPM_HOME/bin.
# Add both for backward compat with existing globals (acorn, gemini, etc.).
if command -v pnpm >/dev/null 2>&1; then
    export PNPM_HOME="$HOME/.local/share/pnpm"
    case ":$PATH:" in
        *":$PNPM_HOME/bin:"*) ;;
        *) export PATH="$PNPM_HOME/bin:$PNPM_HOME:$PATH" ;;
    esac
fi
{{- end }}
