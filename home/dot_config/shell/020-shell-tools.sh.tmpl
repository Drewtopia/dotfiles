#!/usr/bin/env bash

# Shell Enhancement Tools
# Tools that enhance shell experience and productivity

## Navigation & Search Tools

## Shell Integration (only if tools are available)

# fzf — defaults and theme (used by navi, pipes, and other tools that call fzf)
# Keybindings (Ctrl+T, Ctrl+R) handled by television instead
if command -v fzf >/dev/null 2>&1; then
	export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
	export FZF_DEFAULT_OPTS=" \
		--height=40% --layout=reverse --border --info=inline \
		--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
		--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
		--color=marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8 \
		--color=selected-bg:#45475a"
	export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
	export FZF_ALT_C_OPTS="--preview 'eza --tree --level=2 --color=always {} 2>/dev/null || ls {}'"
	eval "$(fzf --zsh)"
fi

if command -v zoxide >/dev/null 2>&1; then
	eval "$(zoxide init zsh)"
fi

# atuin — shell history storage + sync (data backend, no keybindings)
# UI accessed via television's atuin-history channel (Ctrl+R)
if command -v atuin >/dev/null 2>&1; then
	export ATUIN_NOBIND="true"
	if [[ -n ${ZSH_NAME} ]]; then
		eval "$(atuin init zsh)"
		bindkey '^r' atuin-search
		bindkey '^[[A' atuin-up-search
		bindkey '^[OA' atuin-up-search
	elif [[ -n ${BASH} ]]; then
		eval "$(atuin init bash)"
		bind -x '"\C-r": __atuin_history'
		bind -x '"\e[A": __atuin_history --shell-up-key-binding'
		bind -x '"\eOA": __atuin_history --shell-up-key-binding'
	fi
fi

# carapace - universal completion engine
if command -v carapace >/dev/null 2>&1; then
	export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense'
	zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'
	source <(carapace _carapace)
fi

# television - smart fuzzy finder with context-aware channels
# Ctrl+T: smart completion (picks channel based on command, e.g. git checkout → branches)
# Ctrl+R in tv: remote control to switch channels
if command -v tv >/dev/null 2>&1; then
	eval "$(tv init zsh)"
fi

# fnox - secrets manager with shell integration
if command -v fnox >/dev/null 2>&1; then
	if [[ -n ${ZSH_NAME} ]]; then
		eval "$(fnox activate zsh)"
	elif [[ -n ${BASH} ]]; then
		eval "$(fnox activate bash)"
	fi
fi

