[metadata]
name = "chezmoi"
description = "Browse and edit chezmoi-managed dotfiles"
requirements = ["chezmoi", "bat"]

[source]
command = [
  "chezmoi managed --include=files",
  "chezmoi managed --include=scripts",
]

[preview]
{{ if eq .chezmoi.os "windows" -}}
command = "try { chezmoi cat $HOME/'{}' 2>$null | bat -n --color=always --file-name '{}' } catch { bat -n --color=always $HOME/'{}' 2>$null }"
{{ else -}}
command = "chezmoi cat ~/'{}' 2>/dev/null | bat -n --color=always --file-name '{}' || bat -n --color=always ~/'{}' 2>/dev/null"
{{ end -}}

[keybindings]
enter = "actions:edit"
ctrl-d = "actions:diff"
ctrl-a = "actions:apply"

[actions.edit]
description = "Edit the source template in chezmoi"
command = "chezmoi edit {{ if eq .chezmoi.os "windows" }}$HOME{{ else }}~{{ end }}/'{}'"
mode = "execute"

[actions.diff]
description = "Show diff between source and target"
command = "chezmoi diff {{ if eq .chezmoi.os "windows" }}$HOME{{ else }}~{{ end }}/'{}'"
mode = "fork"

[actions.apply]
description = "Apply this specific file"
command = "chezmoi apply {{ if eq .chezmoi.os "windows" }}$HOME{{ else }}~{{ end }}/'{}'"
mode = "fork"
