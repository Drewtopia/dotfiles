[metadata]
name = "pnpm-packages"
description = "Browse project dependencies"
requirements = ["pnpm"]

[source]
command = [
  "pnpm ls --depth 0 --parseable --long {{ if eq .chezmoi.os "windows" }}2>$null{{ else }}2>/dev/null{{ end }}",
  "pnpm ls --depth 0 --parseable --long --dev {{ if eq .chezmoi.os "windows" }}2>$null{{ else }}2>/dev/null{{ end }}",
]
display = "{regex_extract:([^/]+)@([\\d.]+):0}"
output = "{regex_extract:([^/]+)@[\\d.]+:1}"

[preview]
command = "pnpm info '{}' {{ if eq .chezmoi.os "windows" }}2>$null{{ else }}2>/dev/null | head -30{{ end }}"

[keybindings]
enter = "actions:info"
ctrl-u = "actions:update"
ctrl-d = "actions:remove"

[actions.info]
description = "Show package info"
command = "pnpm info '{}'"
mode = "fork"

[actions.update]
description = "Update to latest"
command = "pnpm update '{}'"
mode = "fork"

[actions.remove]
description = "Remove package"
command = "pnpm remove '{}'"
mode = "fork"
