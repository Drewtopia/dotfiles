#!/bin/bash
# cvault — Claude memory vault management CLI
# Mirrors chezmoi's verb structure for ~/.claude-vault/
#
# Subcommands:
#   cvault status    — ahead/behind/uncommitted summary; flags rebase-in-progress
#   cvault diff [..] — pass-through to `git diff` (accepts any args)
#   cvault apply     — commit + push local changes (no-op if clean)
#   cvault update    — git pull --rebase --autostash from origin
#   cvault sync      — update, then apply (full bidirectional sync)
#   cvault merge     — resolve conflicted files via `git mergetool`, then continue rebase
#
# Auto-sync hooks (~/.claude/hooks/memory-{pull,push}.sh) handle the
# ambient case. cvault is for explicit "do it now" usage.

set -e

# Auto-detect vault location:
#   Mac/Linux/personal-Windows: ~/.claude-vault/ (symlinked into ~/.claude/memory)
#   Work Windows (no Developer Mode): ~/.claude/memory/ (direct clone, no symlink)
if [ -d "$HOME/.claude-vault/.git" ]; then
    VAULT_DIR="$HOME/.claude-vault"
elif [ -d "$HOME/.claude/memory/.git" ]; then
    VAULT_DIR="$HOME/.claude/memory"
else
    echo "cvault: no vault found" >&2
    echo "  expected ~/.claude-vault/ (Mac/Linux/personal-Windows)" >&2
    echo "        or ~/.claude/memory/ (work Windows direct-clone)" >&2
    echo "  run \`chezmoi apply\` to clone the vault" >&2
    exit 1
fi

# True if a rebase or merge is mid-flight in the vault repo.
in_progress() {
    [ -d "$VAULT_DIR/.git/rebase-merge" ] \
        || [ -d "$VAULT_DIR/.git/rebase-apply" ] \
        || [ -f "$VAULT_DIR/.git/MERGE_HEAD" ]
}

# Files with unresolved conflict markers, one per line.
conflicted_files() {
    git -C "$VAULT_DIR" diff --name-only --diff-filter=U
}

cmd_status() {
    cd "$VAULT_DIR"
    echo "Vault: $VAULT_DIR"
    echo
    if in_progress; then
        if [ -d .git/rebase-merge ] || [ -d .git/rebase-apply ]; then
            echo "  ⚠  REBASE IN PROGRESS"
        else
            echo "  ⚠  MERGE IN PROGRESS"
        fi
        local conflicted
        conflicted=$(conflicted_files)
        if [ -n "$conflicted" ]; then
            echo "     conflicted files:"
            echo "$conflicted" | sed 's/^/       /'
            echo "     → run \`cvault merge\` to resolve"
        else
            echo "     → no conflicts left; run \`cvault merge\` to continue"
        fi
        echo
    fi
    git fetch --quiet origin 2>/dev/null || echo "  (offline — couldn't fetch)"
    local ahead behind
    ahead=$(git rev-list --count origin/main..HEAD 2>/dev/null || echo 0)
    behind=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo 0)
    echo "  ahead of origin/main:  $ahead"
    echo "  behind origin/main:    $behind"
    echo
    local working_tree
    working_tree=$(git status --short)
    if [ -z "$working_tree" ]; then
        echo "  working tree:          clean"
    else
        echo "  working tree:"
        echo "$working_tree" | sed 's/^/    /'
    fi
    echo
    # Flag any backup dirs that need migration
    local baks
    baks=$(ls -d "$HOME/.claude/memory.bak."* 2>/dev/null || true)
    if [ -n "$baks" ]; then
        echo "  pending migration (run \`reorganize-memory\` skill):"
        echo "$baks" | sed 's/^/    /'
    fi
}

cmd_diff() {
    cd "$VAULT_DIR"
    git diff "$@"
}

cmd_apply() {
    cd "$VAULT_DIR"
    if git diff --quiet && git diff --cached --quiet; then
        echo "cvault: no local changes to apply"
        return 0
    fi
    echo "→ Committing local changes..."
    git add -A
    git commit -m "manual: $(date -u +%Y-%m-%dT%H:%M) via $(hostname)"
    echo "→ Pushing..."
    git push
    echo "✓ Applied"
}

cmd_update() {
    cd "$VAULT_DIR"
    echo "→ Pulling..."
    git pull --rebase --autostash
    echo "✓ Updated"
}

cmd_sync() {
    cmd_update
    cmd_apply
}

cmd_merge() {
    cd "$VAULT_DIR"
    if ! in_progress; then
        echo "cvault: nothing to merge (no rebase or merge in progress)"
        return 0
    fi
    local conflicted
    conflicted=$(conflicted_files)
    if [ -n "$conflicted" ]; then
        echo "→ launching \`git mergetool\` for:"
        echo "$conflicted" | sed 's/^/    /'
        # Don't let mergetool's exit code (non-zero if any file unresolved) kill the script.
        git mergetool || true
        conflicted=$(conflicted_files)
    fi
    if [ -n "$conflicted" ]; then
        echo
        echo "cvault: still unresolved — re-run \`cvault merge\`, or \`git rebase --abort\` to bail"
        return 1
    fi
    if [ -d .git/rebase-merge ] || [ -d .git/rebase-apply ]; then
        echo "→ all conflicts resolved; continuing rebase..."
        git rebase --continue
        echo "✓ Merged"
    elif [ -f .git/MERGE_HEAD ]; then
        echo "→ all conflicts resolved; finalizing merge commit..."
        git commit --no-edit
        echo "✓ Merged (run \`cvault apply\` to push)"
    fi
}

cmd_help() {
    cat <<'EOF'
cvault — Claude memory vault CLI

usage: cvault <command> [args]

  status         Show ahead/behind, working tree, pending migrations
                 (loudly flags any in-progress rebase/merge)
  diff [...]    `git diff` pass-through
  apply          Commit + push local changes
  update         Pull from origin (rebase + autostash)
  sync           update + apply
  merge          Resolve conflicts via `git mergetool` and continue
  help           Show this message

The vault auto-syncs at session boundaries via hooks (~/.claude/hooks/memory-{pull,push}.sh).
Use cvault when you want explicit control.
EOF
}

case "${1:-status}" in
    status)  cmd_status ;;
    diff)    shift; cmd_diff "$@" ;;
    apply)   cmd_apply ;;
    update)  cmd_update ;;
    sync)    cmd_sync ;;
    merge)   cmd_merge ;;
    help|-h|--help) cmd_help ;;
    *)
        echo "cvault: unknown command '$1'" >&2
        echo
        cmd_help >&2
        exit 1
        ;;
esac
