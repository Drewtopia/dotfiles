{{- if eq .chezmoi.os "darwin" }}
# Re-source .zshenv — macOS /etc/zprofile runs path_helper which reorders PATH,
# pushing ~/.local/bin and /opt/homebrew/bin down. Re-sourcing restores priority.
[[ -f ~/.zshenv ]] && source ~/.zshenv

# Homebrew environment (static — faster than eval "$(brew shellenv)")
export HOMEBREW_PREFIX="/opt/homebrew"
export HOMEBREW_CELLAR="/opt/homebrew/Cellar"
export HOMEBREW_REPOSITORY="/opt/homebrew"
export MANPATH="/opt/homebrew/share/man${MANPATH+:$MANPATH}:"
export INFOPATH="/opt/homebrew/share/info:${INFOPATH:-}"

# Obsidian CLI
export PATH="$PATH:/Applications/Obsidian.app/Contents/MacOS"
{{- end }}
