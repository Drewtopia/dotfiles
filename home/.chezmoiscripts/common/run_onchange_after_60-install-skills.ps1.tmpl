{{- if eq .chezmoi.os "windows" -}}
{{- if .dev_computer -}}
# Reconcile agent skills against .chezmoidata/skills.yaml via `npx skills`
# (Windows counterpart of the .sh sibling).
#
# Inlining the desired skills below makes run_onchange retrigger when the
# YAML changes:
{{- range .skill_repos }}
# {{ .repo }}:
{{- range .skills }}
#   {{ . }}
{{- end }}
{{- end }}

$ErrorActionPreference = "Stop"

if (-not (Get-Command npx -ErrorAction SilentlyContinue)) {
    Write-Host "[skills] npx not on PATH; skipping"
    exit 0
}

{{- range .skill_repos }}
Write-Host "[skills] {{ .repo }}: {{ .skills | join ", " }}"
npx -y skills add {{ .repo }} -g -y --skill {{ .skills | join " " }}
{{- end }}

# Sweep up empty skill directories that `npx skills add` leaves behind
# during repo discovery (it scans for all available skills, leaving
# placeholder dirs for ones not in the --skill set).
#
# Two paths to clean: $HOME/.claude/skills/ where npx writes (the source
# of new empties) and the relocated CLAUDE_CONFIG_DIR/skills/ which the
# setup-claude-config sync mirrored old empties to.
foreach ($skillsDir in @("$HOME\.claude\skills", '{{ .directories.claude_dir }}/skills')) {
    if (Test-Path $skillsDir) {
        Get-ChildItem -Path $skillsDir -Directory -ErrorAction SilentlyContinue | Where-Object {
            -not (Get-ChildItem $_.FullName -Force -ErrorAction SilentlyContinue)
        } | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue
    }
}
{{- end }}
{{- end }}
