{{- if and (eq .chezmoi.os "windows") (not .work) -}}
{{- if .dev_computer -}}
# Reconcile agent skills against .chezmoidata/skills.yaml via `npx skills`
# (Windows counterpart of the .sh sibling).
#
# run_onchange: fires only when this rendered script changes, i.e. when
# .chezmoidata/skills.yaml changes the declared repo/skill set. Its job is
# ADDING newly-declared skills. Ongoing UPDATES are owned by topgrade's
# native `skills` step (17.7.0+, see .chezmoitemplates/topgrade.toml).

# Continue past per-repo failures so one bad repo cannot abort siblings.
$ErrorActionPreference = "Continue"

# Refresh PATH from registry. chezmoi-spawned scripts inherit the chezmoi
# parent process env, which doesn't include PATH mutations made by sibling
# scripts (e.g. scoop shims prepended by 05-set-env-vars). Without this,
# npx (a mise shim) resolves but mise.exe doesn't, and the shim errors with
# `mise-shim: failed to execute mise: program not found`.
$env:PATH = [Environment]::GetEnvironmentVariable("PATH", "Machine") + ";" + [Environment]::GetEnvironmentVariable("PATH", "User")

if (-not (Get-Command npx -ErrorAction SilentlyContinue)) {
    Write-Host "[skills] npx not on PATH; skipping"
    exit 0
}

{{- range .skill_repos }}
Write-Host "[skills] {{ .repo }}: {{ .skills | join ", " }}"
try {
    & npx -y skills add {{ .repo }} -g -y --skill {{ .skills | join " " }}
    if ($LASTEXITCODE -ne 0) { throw "npx skills add exited $LASTEXITCODE" }
} catch {
    Write-Warning "[skills] {{ .repo }}: install failed ($_); continuing"
}
{{- end }}

# Sweep up empty skill directories that `npx skills add` leaves behind
# during repo discovery (it scans for all available skills, leaving
# placeholder dirs for ones not in the --skill set).
$skillsDir = "$HOME\.claude\skills"
if (Test-Path $skillsDir) {
    Get-ChildItem -Path $skillsDir -Directory -ErrorAction SilentlyContinue | Where-Object {
        -not (Get-ChildItem $_.FullName -Force -ErrorAction SilentlyContinue)
    } | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue
}
{{- end }}
{{- end }}
