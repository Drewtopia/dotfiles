#!/usr/bin/env bash
# Reconcile Claude Code plugin marketplaces against .chezmoidata/claude.toml.
# For each declared marketplace: register it via `claude plugin marketplace add`
# (no-op if already registered), then refresh all known marketplaces.
#
# Inlining the desired marketplaces below makes run_onchange retrigger when
# claude.toml changes:
{{- range $name, $repo := .marketplaces }}
#   {{ $name }} -> {{ $repo }}
{{- end }}

set -euo pipefail

if ! command -v claude >/dev/null 2>&1; then
  echo "ℹ️  claude CLI not on PATH; skipping marketplace sync" >&2
  exit 0
fi

{{- range $name, $repo := .marketplaces }}
output=$(claude plugin marketplace add {{ $repo }} 2>&1) && \
  echo "✓ marketplace {{ $name }} registered" || \
  echo "  marketplace {{ $name }} already registered (or add failed: ${output})"
{{- end }}

echo "🔄 Refreshing marketplaces..."
if claude plugin marketplace update 2>&1; then
  echo "✓ marketplaces refreshed (restart Claude Code to pick up new plugins)"
else
  echo "⚠️  marketplace update failed — continuing chezmoi apply" >&2
  exit 0
fi
