{{- if .dev_computer }}
#!/usr/bin/env pwsh
# run_onchange: re-fires only when the declared mise tool set changes.
# mise config: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}
# Ongoing tool upgrades are handled by topgrade's native mise step.

# Re-launch with pwsh 7 if running under PowerShell 5.1
if ($PSVersionTable.PSVersion.Major -lt 7) {
    if (Get-Command pwsh -ErrorAction SilentlyContinue) {
        pwsh -NoProfile -File $MyInvocation.MyCommand.Path
        exit $LASTEXITCODE
    }
    Write-Host "[WARN] pwsh 7 not found, running under PowerShell $($PSVersionTable.PSVersion)" -ForegroundColor Yellow
}

# Refresh PATH from registry to pick up scoop shims added by the bootstrap
# script in this same chezmoi run (chezmoi-spawned scripts inherit the parent
# env, so a sibling script's PATH changes aren't visible without this).
$env:PATH = [Environment]::GetEnvironmentVariable("PATH", "Machine") + ";" + [Environment]::GetEnvironmentVariable("PATH", "User")

# mise is installed via scoop in run_onchange_before_10-install-scoop.ps1.tmpl
if (Get-Command mise -ErrorAction SilentlyContinue) {
    if (Get-Command gh -ErrorAction SilentlyContinue) {
        $env:GITHUB_TOKEN = (gh auth token 2>$null)
    }
    # Consolidate mise dirs under .mise (see mise.jdx.dev/how-i-use-mise)
    $miseDir = '{{ .directories.mise_dir }}'
    $oldDataDir = Join-Path $HOME ".local\share\mise"
    if ((Test-Path $oldDataDir) -and -not (Get-Item $oldDataDir -Force).Attributes.ToString().Contains("ReparsePoint")) {
        if ($oldDataDir -ne $miseDir) {
            Write-Host "[Migrate] Moving $oldDataDir -> $miseDir" -ForegroundColor Blue
            New-Item -ItemType Directory -Path $miseDir -Force | Out-Null
            Copy-Item "$oldDataDir\*" $miseDir -Recurse -Force -ErrorAction SilentlyContinue
            Remove-Item $oldDataDir -Recurse -Force -ErrorAction SilentlyContinue
            & cmd /c mklink /J "`"$oldDataDir`"" "`"$miseDir`"" | Out-Null
        }
    }

    mise trust --all 2>$null
    Write-Host "[Install] Installing mise tools..." -ForegroundColor Blue
    mise install --yes
    mise prune --yes 2>$null
} else {
    Write-Host "[WARN] mise not found on PATH. Open a new shell and re-run 'chezmoi apply'." -ForegroundColor Yellow
}
{{- end }}
