{{- if and (eq .chezmoi.os "windows") (not .work) -}}
# Reconcile Claude Code plugin marketplaces against .chezmoidata/claude.toml
# (Windows counterpart of the .sh sibling). Registers each declared
# marketplace via `claude plugin marketplace add` (no-op if already
# registered). Refreshing is handled by topgrade's native Claude Code step.
#
# ASCII-only: chezmoi writes scripts as UTF-8 without BOM, and PowerShell
# defaults to CP1252 parsing on Windows, which mangles multi-byte chars.
#
# Inlining the desired marketplaces below makes run_onchange retrigger when
# claude.toml changes:
{{- range $name, $repo := .marketplaces }}
#   {{ $name }} -> {{ $repo }}
{{- end }}

$ErrorActionPreference = "Stop"

if (-not (Get-Command claude -ErrorAction SilentlyContinue)) {
    Write-Host 'i  claude CLI not on PATH; skipping marketplace sync'
    exit 0
}

{{- range $name, $repo := .marketplaces }}
$output = & claude plugin marketplace add {{ $repo }} 2>&1
if ($LASTEXITCODE -eq 0) {
    Write-Host '[ok]   marketplace {{ $name }} registered' -ForegroundColor Green
} else {
    Write-Host '[skip] marketplace {{ $name }} already registered or add failed' -ForegroundColor DarkGray
}
{{- end }}
{{- end -}}
