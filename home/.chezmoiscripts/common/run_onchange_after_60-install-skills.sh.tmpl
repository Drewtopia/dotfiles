{{- if ne .chezmoi.os "windows" -}}
{{- if .dev_computer -}}
#!/usr/bin/env bash
# Reconcile agent skills against .chezmoidata/skills.yaml via `npx skills`.
# Replaces the old static $mattSkills list in .chezmoiexternal.toml.tmpl,
# which went stale every time Pocock refactored upstream. The CLI tracks
# whatever's currently in each declared repo.
#
# Inlining the desired skills below makes run_onchange retrigger when the
# YAML changes:
{{- range .skill_repos }}
# {{ .repo }}:
{{- range .skills }}
#   {{ . }}
{{- end }}
{{- end }}

set -euo pipefail

if ! command -v npx >/dev/null 2>&1; then
    echo "[skills] npx not on PATH; skipping"
    exit 0
fi

{{- range .skill_repos }}
echo "[skills] {{ .repo }}: {{ .skills | join ", " }}"
npx -y skills add {{ .repo }} -g -y --skill {{ .skills | join " " }}
{{- end }}

# Sweep up empty skill directories that `npx skills add` leaves behind
# during repo discovery (it scans for all available skills, leaving
# placeholder dirs for ones not in the --skill set).
#
# Two paths to clean: $HOME/.claude/skills/ where npx writes (the source
# of new empties) and the relocated CLAUDE_CONFIG_DIR/skills/ which the
# setup-claude-config sync mirrored old empties to.
find "$HOME/.claude/skills" -mindepth 1 -maxdepth 1 -type d -empty -delete 2>/dev/null || true
find "{{ .directories.claude_dir }}/skills" -mindepth 1 -maxdepth 1 -type d -empty -delete 2>/dev/null || true
{{- end }}
{{- end }}
