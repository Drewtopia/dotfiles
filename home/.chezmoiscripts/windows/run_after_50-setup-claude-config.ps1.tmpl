{{- if and (eq .chezmoi.os "windows") (ne .directories.tools_root .chezmoi.homeDir) -}}
#!/usr/bin/env pwsh
# Sync chezmoi-managed claude files from ~/.claude to relocated CLAUDE_CONFIG_DIR.
# Chezmoi manages ~/.claude normally (templates + externals), this script mirrors
# the managed files to the path Claude actually reads from.
$ErrorActionPreference = "Stop"

$src = Join-Path $HOME ".claude"
$dst = '{{ .directories.claude_dir }}'

if (-not (Test-Path $src)) { exit 0 }
if (-not (Test-Path $dst)) { New-Item -ItemType Directory -Path $dst -Force | Out-Null }

# Sync managed files and directories
$items = @('CLAUDE.md', 'settings.json', 'mcp.json', 'hooks', 'skills', 'commands', 'agents')
foreach ($item in $items) {
    $s = Join-Path $src $item
    if (-not (Test-Path $s)) { continue }
    $d = Join-Path $dst $item
    if (Test-Path $s -PathType Container) {
        if (-not (Test-Path $d)) { New-Item -ItemType Directory -Path $d -Force | Out-Null }
        Copy-Item "$s/*" $d -Recurse -Force
    } else {
        Copy-Item $s $d -Force
    }
}

# Copy cvault from chezmoi source (ignored by chezmoi when relocated due to .local/bin junction)
$cvaultSrc = '{{ .chezmoi.sourceDir }}/home/dot_local/bin/executable_cvault'
$cvaultDst = '{{ .directories.tools_root }}/.local/bin/cvault'
if (Test-Path $cvaultSrc) {
    try {
        Copy-Item $cvaultSrc $cvaultDst -Force
    } catch {
        Write-Host "[Claude] cvault copy skipped (likely in use): $($_.Exception.Message)" -ForegroundColor Yellow
    }
}

Write-Host "[Claude] Config synced to $dst" -ForegroundColor Green
{{- end }}
