{{- if and (eq .chezmoi.os "windows") (lookPath "op") (or .work .personal) -}}
#!/usr/bin/env pwsh
# Wake the 1Password desktop app before chezmoi renders op-backed templates
# (dot_ssh/private_id_ed25519.tmpl calls `onepasswordRead`).
#
# op's desktop-app handshake timeout is fixed and short. On a cold or locked
# app, op opens the approval window AND starts its countdown at the same time;
# manually entering a password takes longer than the countdown, so op returns
# `exit 1` ("connecting to desktop app timed out") even though the user did
# approve. That aborts the whole `chezmoi apply`.
#
# This loop absorbs the race: the first attempt's approval warms + unlocks the
# app (op itself still times out), and a later attempt then connects instantly
# against the now-unlocked app. The user authenticates once. Once op succeeds
# here the session is live, so chezmoi's subsequent onepasswordRead reuses it.
#
# Non-fatal: if op never connects the apply continues; the SSH key template
# has its own non-op fallback branch.
$ErrorActionPreference = "Continue"

# Refresh PATH from registry so op.exe resolves in this chezmoi-spawned
# subprocess (same rationale as run_after_60-install-skills.ps1.tmpl).
$env:PATH = [Environment]::GetEnvironmentVariable("PATH", "Machine") + ";" + [Environment]::GetEnvironmentVariable("PATH", "User")

if (-not (Get-Command op -ErrorAction SilentlyContinue)) {
    Write-Host "[1password] op not on PATH; skipping pre-warm"
    exit 0
}

for ($i = 1; $i -le 8; $i++) {
    & op whoami 2>$null | Out-Null
    if ($LASTEXITCODE -eq 0) {
        Write-Host "[1password] session warm" -ForegroundColor Green
        exit 0
    }
    Write-Host "[1password] attempt $i/8 - approve the 1Password prompt; retrying..." -ForegroundColor Yellow
    Start-Sleep -Seconds 4
}

Write-Host "[1password] WARNING: could not warm op session; op-backed templates may fail this apply" -ForegroundColor Red
{{- end }}
