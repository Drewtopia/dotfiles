{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
# Single source of truth for User-scope environment variables that
# locate relocated dev tooling. Runs before any other onchange script
# that might depend on these values (install-scoop, mise tools, etc.).
$ErrorActionPreference = "Stop"

{{- if ne .directories.tools_root .chezmoi.homeDir }}
Write-Host "[Relocation] Dev tools under {{ .directories.tools_root }} (override via `dev_folder` prompt)" -ForegroundColor Cyan
{{- end }}

$envVars = [ordered]@{
    'XDG_CONFIG_HOME'   = '{{ .directories.xdg_config_dir }}'
    'XDG_DATA_HOME'     = '{{ .directories.xdg_data_dir }}'
    'XDG_STATE_HOME'    = '{{ .directories.xdg_state_dir }}'
    'XDG_CACHE_HOME'    = '{{ .directories.xdg_cache_dir }}'
    'MISE_DATA_DIR'     = '{{ .directories.mise_dir }}'
    'PNPM_HOME'         = '{{ .directories.pnpm_home }}'
{{- if ne .directories.tools_root .chezmoi.homeDir }}
    'CLAUDE_CONFIG_DIR'     = '{{ .directories.claude_dir }}'
    'SCOOP'                 = '{{ .directories.tools_root }}/scoop'
    # uv defaults land in %APPDATA%\uv (venvs) and ~/.local/bin (trampolines);
    # endpoint security blocks execution of the venv's python.exe from there.
    # Relocate everything uv-managed under tools_root.
    'UV_TOOL_DIR'           = '{{ .directories.tools_root }}/.local/share/uv/tools'
    'UV_TOOL_BIN_DIR'       = '{{ .directories.tools_root }}/.local/bin'
    'UV_PYTHON_INSTALL_DIR' = '{{ .directories.tools_root }}/.local/share/uv/python'
    'UV_CACHE_DIR'          = '{{ .directories.xdg_cache_dir }}/uv'
    # cargo's bin and rustup's toolchains land in ~/.cargo and ~/.rustup by
    # default (both outside the whitelisted dev path).
    'CARGO_HOME'            = '{{ .directories.tools_root }}/.cargo'
    'RUSTUP_HOME'           = '{{ .directories.tools_root }}/.rustup'
    # bun's per-user install dir (where `bun add -g` lands binaries).
    'BUN_INSTALL'           = '{{ .directories.tools_root }}/.bun'
    # deno: install root for `deno install`-produced binaries; cache holds
    # compiled artifacts that get exec'd directly.
    'DENO_INSTALL_ROOT'     = '{{ .directories.tools_root }}/.deno/bin'
    'DENO_DIR'              = '{{ .directories.xdg_cache_dir }}/deno'
    # go: workspace at the conventional path, but route `go install` binaries
    # into the already-whitelisted .local/bin (same place uv trampolines live).
    'GOPATH'                = '{{ .directories.tools_root }}/go'
    'GOBIN'                 = '{{ .directories.tools_root }}/.local/bin'
{{- end }}
}

foreach ($kv in $envVars.GetEnumerator()) {
    $current = [Environment]::GetEnvironmentVariable($kv.Key, 'User')
    if ($current -ne $kv.Value) {
        Write-Host "[Env] Setting $($kv.Key) = $($kv.Value)" -ForegroundColor Blue
        [Environment]::SetEnvironmentVariable($kv.Key, $kv.Value, 'User')
    }
    Set-Item -Path "Env:$($kv.Key)" -Value $kv.Value
}

# Clean + normalize User PATH, ensure mise + scoop shims are first.
#
# Why touch User PATH at all: GUI apps (VS Code, JetBrains, etc.) only
# inherit Windows User PATH at launch; the PowerShell profile patches
# terminal PATH but never reaches GUI processes. Extensions like
# biomejs.biome scan PATH and otherwise fail with "Unable to find the
# Biome binary".
#
# Why scoop shims is entry 1: every mise shim execs `mise` to resolve
# the underlying binary. mise itself is installed via scoop, so its
# exe lives under $SCOOP/shims. Without that on User PATH, every mise
# shim fails with "mise-shim: failed to execute mise: program not found"
# under GUI processes (and any pwsh that doesn't run the profile).
#
# Self-heal on every apply:
#   - normalize to backslashes, strip trailing \ and \.
#   - drop entries pointing at non-existent dirs (uninstalls leave junk)
#   - dedup case-insensitively, preserving first occurrence
#   - guarantee mise shims is entry 0, scoop shims is entry 1
$miseShims  = '{{ .directories.mise_dir }}/shims' -replace '/', '\'
$scoopRoot  = if ($env:SCOOP) { $env:SCOOP } else { Join-Path $HOME 'scoop' }
$scoopShims = (Join-Path $scoopRoot 'shims') -replace '/', '\'
$prepend    = @($miseShims, $scoopShims)
$userPath   = [Environment]::GetEnvironmentVariable('Path', 'User')
$raw        = if ($userPath) { $userPath -split ';' | Where-Object { $_ } } else { @() }

$cleaned = [System.Collections.Generic.List[string]]::new()
$seen    = [System.Collections.Generic.HashSet[string]]::new([StringComparer]::OrdinalIgnoreCase)
foreach ($p in $prepend + $raw) {
    $n = ($p -replace '/', '\').TrimEnd('\') -replace '\\\.$', ''
    if ([string]::IsNullOrWhiteSpace($n)) { continue }
    if (-not (Test-Path -LiteralPath $n)) { continue }
    if (-not $seen.Add($n)) { continue }
    [void]$cleaned.Add($n)
}

$newUserPath = $cleaned -join ';'
if ($newUserPath -ne $userPath) {
    $removed = ($raw.Count + $prepend.Count) - $cleaned.Count
    Write-Host "[Env] Rewriting User PATH ($($raw.Count) -> $($cleaned.Count) entries, $removed pruned/normalized)" -ForegroundColor Blue
    [Environment]::SetEnvironmentVariable('Path', $newUserPath, 'User')
}
foreach ($shim in $prepend) {
    if ((Test-Path -LiteralPath $shim) -and -not ($env:Path -split ';' | Where-Object { $_ -ieq $shim })) {
        $env:Path = "$shim;$env:Path"
    }
}

# GITHUB_TOKEN: source from gh CLI (already authed via 'gh auth login'). Set
# as User-scope so child processes inherit it (including WSL via interop,
# provided GITHUB_TOKEN is also in WSLENV; see below). Fixes mise rate-limit
# when topgrade crosses Windows -> WSL non-interactively.
if (Get-Command gh -ErrorAction SilentlyContinue) {
    $ghToken = (& gh auth token 2>$null)
    if ($LASTEXITCODE -eq 0 -and $ghToken) {
        $ghToken = $ghToken.Trim()
        $current = [Environment]::GetEnvironmentVariable('GITHUB_TOKEN', 'User')
        if ($current -ne $ghToken) {
            Write-Host '[Env] Setting GITHUB_TOKEN from gh auth token' -ForegroundColor Blue
            [Environment]::SetEnvironmentVariable('GITHUB_TOKEN', $ghToken, 'User')
        }
        Set-Item -Path 'Env:GITHUB_TOKEN' -Value $ghToken
    } else {
        Write-Host '[Env] gh auth token returned empty; run `gh auth login` then re-apply' -ForegroundColor Yellow
    }
} else {
    Write-Host '[Env] gh CLI not on PATH; GITHUB_TOKEN not set' -ForegroundColor DarkGray
}

# WSLENV: ensure GITHUB_TOKEN propagates into WSL processes invoked via interop
# (e.g. topgrade -> WSL mise). WSLENV is colon-separated and may contain other
# entries; merge, don't overwrite.
$wantWslEnv = 'GITHUB_TOKEN'
$currentWslEnv = [Environment]::GetEnvironmentVariable('WSLENV', 'User')
$parts = if ($currentWslEnv) { $currentWslEnv -split ':' } else { @() }
if ($parts -notcontains $wantWslEnv) {
    $newWslEnv = (@($parts | Where-Object { $_ }) + $wantWslEnv) -join ':'
    Write-Host "[Env] Appending $wantWslEnv to WSLENV" -ForegroundColor Blue
    [Environment]::SetEnvironmentVariable('WSLENV', $newWslEnv, 'User')
    Set-Item -Path 'Env:WSLENV' -Value $newWslEnv
}
{{- end }}
