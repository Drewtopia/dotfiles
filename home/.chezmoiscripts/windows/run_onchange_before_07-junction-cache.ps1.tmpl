{{- if eq .chezmoi.os "windows" -}}
{{- if ne .directories.tools_root .chezmoi.homeDir -}}
#!/usr/bin/env pwsh
# Junction ~/.cache → relocated cache. Some Node packages (e.g. reflink)
# write to ~/.cache literally via os.homedir(), bypassing XDG_CACHE_HOME,
# which lands them outside the whitelisted dev path and trips endpoint
# security. Junction the directory so any tool that uses ~/.cache writes
# into the relocated path transparently.
#
# Idempotent: skips if junction already in place; merges existing real
# dir into the relocated target before junctioning so cached data isn't
# lost on first run.
$ErrorActionPreference = "Stop"

$src = Join-Path $HOME ".cache"
$dst = '{{ .directories.xdg_cache_dir }}'

if (-not (Test-Path $dst)) {
    New-Item -ItemType Directory -Path $dst -Force | Out-Null
}

if (Test-Path $src) {
    $isJunction = (Get-Item $src -Force).Attributes.ToString().Contains("ReparsePoint")
    if ($isJunction) { return }

    Write-Host "[Migrate] Merging $src into $dst (newer files preferred)..." -ForegroundColor Blue
    # /E + /XO = recurse, only copy when source is newer or dst missing
    robocopy $src $dst /E /XO /R:0 /W:0 /NFL /NDL /NJH /NJS | Out-Null

    Write-Host "[Migrate] Removing original $src..." -ForegroundColor Blue
    Remove-Item $src -Recurse -Force -ErrorAction SilentlyContinue
    if (Test-Path $src) {
        cmd /c rmdir /s /q "`"$src`"" 2>&1 | Out-Null
    }
}

if (-not (Test-Path $src)) {
    Write-Host "[Junction] $src -> $dst" -ForegroundColor Cyan
    cmd /c mklink /J "`"$src`"" "`"$dst`"" | Out-Null
}
{{- end }}
{{- end }}
