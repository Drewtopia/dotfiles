{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh

# Setup Kanata on Windows
# hash: {{ printf "%s%s%s%s" (include "dot_config/kanata/kanata.kbd.tmpl") (include "dot_config/kanata/shared.kbd") (include "dot_config/kanata/windows.kbd") (include "dot_config/kanata/macos-macbook.kbd") | sha256sum }}
#
# Windows uses native LLHOOK (no driver needed). Behavior depends on
# whether this is a personal or work machine:
#
#   Personal (.personal = true): register scheduled task at logon,
#     start kanata now. Kanata auto-starts on every boot.
#
#   Work (.personal = false): DO NOT register the scheduled task.
#     Reason: when you remote into this machine via Jump Desktop from
#     the Mac, your Mac kanata has already remapped the keystroke -
#     running kanata on Windows too would double-remap. Instead, the
#     PowerShell profile exposes `kanata-on` / `kanata-off` functions
#     for manual toggling when you're physically in office.

Write-Host "[Windows] Setting up Kanata..." -ForegroundColor Green

$kanataPath = (Get-Command kanata -ErrorAction SilentlyContinue).Source
$configPath = "{{ .chezmoi.homeDir }}\.config\kanata\kanata.kbd"
$taskName = "Kanata"

if (-not $kanataPath) {
    Write-Host "[WARN] Kanata not installed, skipping setup" -ForegroundColor Yellow
    Write-Host "       Install with: scoop install kanata" -ForegroundColor Yellow
    exit 0
}

if (-not (Test-Path $configPath)) {
    Write-Host "[WARN] Kanata config not found at $configPath" -ForegroundColor Yellow
    exit 0
}

Write-Host "[Info] Kanata binary: $kanataPath" -ForegroundColor Cyan
Write-Host "[Info] Config file: $configPath" -ForegroundColor Cyan

{{ if .personal -}}
# -------------------------------------------------------------------
# Personal machine: Startup folder shortcut, auto-start at logon
#
# Why not Task Scheduler: on some Windows builds / policies, even
# user-scope task registration with LogonType=Interactive is denied
# at the service level. The Startup folder only needs HKCU + profile
# write access, which non-admins always have.
# -------------------------------------------------------------------
Write-Host "[Info] Personal host - creating Startup folder shortcut" -ForegroundColor Cyan

# Transition: remove any pre-existing scheduled task left by the prior approach.
$existingTask = Get-ScheduledTask -TaskName $taskName -ErrorAction SilentlyContinue
if ($existingTask) {
    Write-Host "[Info] Removing legacy Kanata scheduled task..." -ForegroundColor Cyan
    Unregister-ScheduledTask -TaskName $taskName -Confirm:$false -ErrorAction SilentlyContinue
}

$startup  = [Environment]::GetFolderPath('Startup')
$shortcut = Join-Path $startup 'Kanata.lnk'

Write-Host "[Install] Writing $shortcut..." -ForegroundColor Blue
try {
    $wsh = New-Object -ComObject WScript.Shell
    $lnk = $wsh.CreateShortcut($shortcut)
    $lnk.TargetPath  = $kanataPath
    $lnk.Arguments   = '--cfg "{0}"' -f $configPath
    $lnk.WindowStyle = 7    # minimised - kanata has no useful UI
    $lnk.Description = 'Kanata keyboard remapper (auto-start at logon)'
    $lnk.Save()
    Write-Host "[OK] Startup shortcut created" -ForegroundColor Green
} catch {
    Write-Host "[ERROR] Failed to create startup shortcut: $($_.Exception.Message)" -ForegroundColor Red
    exit 1
}

# Best-effort start for the current session.
Write-Host "[Info] Starting Kanata..." -ForegroundColor Cyan
$running = Get-Process kanata -ErrorAction SilentlyContinue
if ($running) {
    Write-Host "[Info] Kanata already running (pid $($running.Id -join ', '))" -ForegroundColor Cyan
} else {
    try {
        Start-Process -FilePath $kanataPath `
            -ArgumentList ('--cfg "{0}"' -f $configPath) `
            -WindowStyle Hidden -ErrorAction Stop
        Write-Host "[OK] Kanata started" -ForegroundColor Green
    } catch {
        Write-Host "[WARN] Could not start Kanata now: $($_.Exception.Message)" -ForegroundColor Yellow
        Write-Host "       It will start at next logon via the Startup shortcut." -ForegroundColor Yellow
    }
}

Write-Host ""
Write-Host "[OK] Kanata setup complete!" -ForegroundColor Green
Write-Host ""
Write-Host "   Commands:" -ForegroundColor Cyan
Write-Host "   - Check status: Get-Process kanata"
Write-Host "   - Stop:         Get-Process kanata | Stop-Process"
Write-Host "   - Open folder:  start shell:startup"
Write-Host ""
{{- else -}}
# -------------------------------------------------------------------
# Work machine: NO auto-start (Jump Desktop double-remap protection)
# Clean up any pre-existing task that a previous apply might have left.
# -------------------------------------------------------------------
Write-Host "[Info] Work/non-personal host - skipping auto-start registration" -ForegroundColor Cyan
Write-Host "[Info] Reason: protects against double-remap when using Jump Desktop from macOS" -ForegroundColor Cyan

$existingTask = Get-ScheduledTask -TaskName $taskName -ErrorAction SilentlyContinue
if ($existingTask) {
    Write-Host "[Cleanup] Removing stale Kanata scheduled task..." -ForegroundColor Yellow
    Unregister-ScheduledTask -TaskName $taskName -Confirm:$false -ErrorAction SilentlyContinue
}

$staleShortcut = Join-Path ([Environment]::GetFolderPath('Startup')) 'Kanata.lnk'
if (Test-Path $staleShortcut) {
    Write-Host "[Cleanup] Removing stale Kanata startup shortcut..." -ForegroundColor Yellow
    Remove-Item $staleShortcut -Force -ErrorAction SilentlyContinue
}

# Stop any currently-running kanata so nothing is left active by surprise.
$running = Get-Process kanata -ErrorAction SilentlyContinue
if ($running) {
    Write-Host "[Cleanup] Stopping running kanata process(es)..." -ForegroundColor Yellow
    $running | Stop-Process -Force -ErrorAction SilentlyContinue
}

Write-Host ""
Write-Host "[OK] Kanata installed but not auto-started." -ForegroundColor Green
Write-Host ""
Write-Host "   Use these pwsh functions when physically at the keyboard:" -ForegroundColor Cyan
Write-Host "   - kanata-on     # start kanata"
Write-Host "   - kanata-off    # stop kanata"
Write-Host "   - kanata-status # show whether it is running"
Write-Host ""
{{- end }}
{{- end }}
