{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh

# Install Scoop package manager and essential tools
# This script runs when its content changes

Write-Host "[Windows] Setting up environment and Scoop..." -ForegroundColor Green

# PSModulePath fix: pwsh 7's installer prepends PS 7 module paths to the
# User-scope PSModulePath env var, which then leaks into PS 5.1's session.
# PS 5.1 walks the list in order and loads PS 7's slimmer
# Microsoft.PowerShell.Utility — which DOESN'T export Get-FileHash or
# New-TemporaryFile (those moved to Management in PS 7), breaking scoop's
# checksum verification. Reset to PS 5.1's default paths for the duration
# of this script.
if ($PSVersionTable.PSEdition -eq 'Desktop') {
    $env:PSModulePath = @(
        (Join-Path $env:USERPROFILE 'Documents\WindowsPowerShell\Modules'),
        (Join-Path $env:ProgramFiles 'WindowsPowerShell\Modules'),
        (Join-Path $env:windir       'system32\WindowsPowerShell\v1.0\Modules')
    ) -join ';'
}

$PSModuleAutoLoadingPreference = 'All'
Import-Module Microsoft.PowerShell.Utility -Force -ErrorAction SilentlyContinue
if (-not (Get-Command Get-FileHash -ErrorAction SilentlyContinue)) {
    Write-Host "[ERROR] Get-FileHash still unavailable - scoop installs will fail." -ForegroundColor Red
    exit 1
}

# Set CurrentUser execution policy via registry to avoid loading the
# Security module's Set-ExecutionPolicy cmdlet. On some locked-down hosts the
# module import can fail and break downstream commands.
$psPolicyKey = 'HKCU:\Software\Microsoft\PowerShell\1\ShellIds\Microsoft.PowerShell'
try {
    if (-not (Test-Path $psPolicyKey)) {
        New-Item -Path $psPolicyKey -Force | Out-Null
    }
    $current = (Get-ItemProperty -Path $psPolicyKey -Name ExecutionPolicy -ErrorAction SilentlyContinue).ExecutionPolicy
    if ($current -ne 'RemoteSigned') {
        Set-ItemProperty -Path $psPolicyKey -Name ExecutionPolicy -Value 'RemoteSigned' -Type String
        Write-Host '[Env] Set CurrentUser ExecutionPolicy = RemoteSigned (via registry)' -ForegroundColor Blue
    }
} catch {
    Write-Host "[WARN] Could not set ExecutionPolicy via registry: $($_.Exception.Message)" -ForegroundColor Yellow
}

function Test-Command($cmdname) {
    return [bool](Get-Command -Name $cmdname -ErrorAction SilentlyContinue)
}

# Inherit env vars from run_onchange_before_05-set-env-vars (chezmoi
# spawns each script as a fresh subprocess, so values that script
# wrote to User scope aren't auto-propagated into this one's env).
foreach ($v in 'SCOOP') {
    $userVal = [Environment]::GetEnvironmentVariable($v, 'User')
    if ($userVal) { Set-Item -Path "Env:$v" -Value $userVal }
}

# Detect scoop without relying on Get-Command alone — the chezmoi subprocess
# may have a PATH that doesn't yet include scoop's shims dir even when scoop
# is fully installed on disk. Probe filesystem first, then PATH.
$scoopRoot   = if ($env:SCOOP) { $env:SCOOP } else { Join-Path $HOME 'scoop' }
$scoopShims  = Join-Path $scoopRoot 'shims'
$scoopInstalled = (Test-Path (Join-Path $scoopShims 'scoop.ps1')) -or (Test-Command scoop)

# Make sure scoop's shims are on PATH for the rest of this script.
if ((Test-Path $scoopShims) -and -not ($env:Path -split ';' | Where-Object { $_ -ieq $scoopShims })) {
    $env:Path = "$scoopShims;$env:Path"
}

if (-not $scoopInstalled) {
    Write-Host "[Install] Installing Scoop..." -ForegroundColor Blue
    # Run the upstream installer in a fresh `pwsh -NoProfile` subprocess.
    # The current shell may have a partially-loaded Microsoft.PowerShell.Security
    # module (FormatXmlUpdateException on re-import), which breaks the
    # installer's internal Get-ExecutionPolicy call. A fresh runtime loads the
    # module cleanly.
    $pwshCmd = Get-Command pwsh -ErrorAction SilentlyContinue
    if (-not $pwshCmd) { $pwshCmd = Get-Command powershell -ErrorAction SilentlyContinue }
    if (-not $pwshCmd) {
        Write-Host '[ERROR] No pwsh/powershell on PATH to run Scoop installer' -ForegroundColor Red
        exit 1
    }
    $pwshExe = $pwshCmd.Source
    & $pwshExe -NoProfile -Command 'irm get.scoop.sh | iex'
    if ($LASTEXITCODE -ne 0) {
        Write-Host "[ERROR] Scoop installer exited $LASTEXITCODE" -ForegroundColor Red
        exit 1
    }
    # Refresh PATH in current process so the rest of this script can call scoop.
    $env:Path = [Environment]::GetEnvironmentVariable('Path','Machine') + ';' + [Environment]::GetEnvironmentVariable('Path','User')
    if ((Test-Path $scoopShims) -and -not ($env:Path -split ';' | Where-Object { $_ -ieq $scoopShims })) {
        $env:Path = "$scoopShims;$env:Path"
    }
    Write-Host "[OK] Scoop installed successfully" -ForegroundColor Green
} else {
    Write-Host "[OK] Scoop already installed; running scoop update" -ForegroundColor Green
    scoop update *>$null
}

# Add scoop buckets. Declared in home/.chezmoidata/scoop.toml.
# Common buckets are scoop's known ones (no URL needed). Work
# buckets may be third-party — URL is looked up via bucket_urls.
$buckets = @(
{{- range .scoop.buckets }}
    '{{ . }}'
{{- end }}
{{- if .work }}
{{- range .scoop.work.buckets }}
    '{{ . }}'
{{- end }}
{{- end }}
)
$bucketUrls = @{
{{- range $name, $url := .scoop.bucket_urls }}
    '{{ $name }}' = '{{ $url }}'
{{- end }}
}

# Cache bucket list once — avoids spawning `scoop bucket list` per iteration.
$bucketNames = scoop bucket list 2>$null | ForEach-Object { $_.Name }

foreach ($bucket in $buckets) {
    if ($bucket -notin $bucketNames) {
        $url = $bucketUrls[$bucket]
        if ($url) {
            Write-Host "[Install] Adding Scoop bucket: $bucket ($url)" -ForegroundColor Blue
            scoop bucket add $bucket $url
        } else {
            Write-Host "[Install] Adding Scoop bucket: $bucket" -ForegroundColor Blue
            scoop bucket add $bucket
        }
    } else {
        Write-Host "[OK] Scoop bucket '$bucket' already added" -ForegroundColor Green
    }
}

# Install essential CLI tools via Scoop. Declared in
# home/.chezmoidata/scoop.toml; [scoop.work] entries appended when
# .work is true.
$scoopPackages = @(
{{- range .scoop.packages }}
    '{{ . }}'
{{- end }}
{{- if .work }}
{{- range .scoop.work.packages }}
    '{{ . }}'
{{- end }}
{{- end }}
)

# scoop list includes packages whose Install failed - clear those first so
# the install loop below retries them instead of skipping as "already installed".
$failedInstalls = scoop list 2>$null | Where-Object { $_.Info -eq 'Install failed' } | ForEach-Object { $_.Name }
foreach ($f in $failedInstalls) {
    if ($f -in $scoopPackages) {
        Write-Host "[Cleanup] Removing failed prior install: $f" -ForegroundColor Yellow
        scoop uninstall $f 2>$null | Out-Null
    }
}

# Get list of installed packages (post-cleanup)
$installedPackages = scoop list 2>$null | ForEach-Object { $_.Name }

Write-Host "[Install] Installing essential CLI tools via Scoop..." -ForegroundColor Blue
$failedPackages = @()
foreach ($package in $scoopPackages) {
    if ($package -notin $installedPackages) {
        Write-Host "Installing $package..." -ForegroundColor Cyan
        scoop install $package
        if ($LASTEXITCODE -ne 0) {
            $failedPackages += $package
            Write-Host "[ERROR] Failed to install $package (exit $LASTEXITCODE)" -ForegroundColor Red
        }
    } else {
        Write-Host "[OK] $package already installed" -ForegroundColor Green
    }
}

if ($failedPackages.Count -gt 0) {
    Write-Host "[ERROR] Scoop install failures: $($failedPackages -join ', ')" -ForegroundColor Red
    exit 1
}

Write-Host "[OK] Scoop setup completed!" -ForegroundColor Green
{{- end }}