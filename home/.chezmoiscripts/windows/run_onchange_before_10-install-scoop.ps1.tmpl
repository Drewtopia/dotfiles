{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh

# Install Scoop package manager and essential tools
# This script runs when its content changes

Write-Host "[Windows] Setting up environment and Scoop..." -ForegroundColor Green

# Ensure utility cmdlets (Get-FileHash, Invoke-WebRequest, etc.) are available.
# Corporate group policy may set $PSModuleAutoLoadingPreference = 'None', which
# breaks scoop's internal use of Get-FileHash to verify download checksums.
Import-Module Microsoft.PowerShell.Utility -ErrorAction SilentlyContinue

function Test-Command($cmdname) {
    return [bool](Get-Command -Name $cmdname -ErrorAction SilentlyContinue)
}

# Set XDG Base Directory environment variables (permanent user-level)
# Ensures Neovim and other XDG-aware tools find configs in ~/.config
$xdgVars = @{
    'XDG_CONFIG_HOME' = '{{ .directories.xdg_config_dir }}'
    'XDG_DATA_HOME'   = '{{ .directories.xdg_data_dir }}'
    'XDG_STATE_HOME'  = '{{ .directories.xdg_state_dir }}'
    'XDG_CACHE_HOME'  = '{{ .directories.xdg_cache_dir }}'
}

foreach ($var in $xdgVars.GetEnumerator()) {
    $current = [Environment]::GetEnvironmentVariable($var.Key, 'User')
    if ($current -ne $var.Value) {
        Write-Host "[Config] Setting $($var.Key)" -ForegroundColor Blue
        [Environment]::SetEnvironmentVariable($var.Key, $var.Value, 'User')
        Set-Item -Path "Env:$($var.Key)" -Value $var.Value
    }
}

# Consolidate mise directories under .mise (see mise.jdx.dev/how-i-use-mise)
$miseDataDir = '{{ .directories.mise_dir }}'
$currentMise = [Environment]::GetEnvironmentVariable('MISE_DATA_DIR', 'User')
if ($currentMise -ne $miseDataDir) {
    Write-Host "[Config] Setting MISE_DATA_DIR = $miseDataDir" -ForegroundColor Blue
    [Environment]::SetEnvironmentVariable('MISE_DATA_DIR', $miseDataDir, 'User')
    Set-Item -Path "Env:MISE_DATA_DIR" -Value $miseDataDir
}

{{ if ne .directories.tools_root .chezmoi.homeDir -}}
# Relocate Claude config to custom tools root
$claudeDir = '{{ .directories.claude_dir }}'
$currentClaude = [Environment]::GetEnvironmentVariable('CLAUDE_CONFIG_DIR', 'User')
if ($currentClaude -ne $claudeDir) {
    Write-Host "[Config] Setting CLAUDE_CONFIG_DIR = $claudeDir" -ForegroundColor Blue
    [Environment]::SetEnvironmentVariable('CLAUDE_CONFIG_DIR', $claudeDir, 'User')
    Set-Item -Path "Env:CLAUDE_CONFIG_DIR" -Value $claudeDir
}

# Relocate scoop to custom tools root
$scoopDir = '{{ .directories.tools_root }}/scoop'
$currentScoop = [Environment]::GetEnvironmentVariable('SCOOP', 'User')
if ($currentScoop -ne $scoopDir) {
    Write-Host "[Config] Setting SCOOP = $scoopDir" -ForegroundColor Blue
    [Environment]::SetEnvironmentVariable('SCOOP', $scoopDir, 'User')
    Set-Item -Path "Env:SCOOP" -Value $scoopDir
}
{{ end -}}

# Install Scoop if not already installed
if (-not (Test-Command scoop)) {
    Write-Host "[Install] Installing Scoop..." -ForegroundColor Blue
    try {
        # Set execution policy for current user
        Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser -Force

        # Install Scoop
        irm get.scoop.sh | iex

        Write-Host "[OK] Scoop installed successfully" -ForegroundColor Green
    } catch {
        Write-Host "[ERROR] Scoop installation failed: $($_.Exception.Message)" -ForegroundColor Red
        exit 1
    }
} else {
    Write-Host "[OK] Scoop already installed" -ForegroundColor Green
}

# Add extra buckets for more packages
$buckets = @('extras', 'nerd-fonts')
foreach ($bucket in $buckets) {
    $bucketList = scoop bucket list 2>$null
    if ($bucketList -notcontains $bucket) {
        Write-Host "[Install] Adding Scoop bucket: $bucket" -ForegroundColor Blue
        scoop bucket add $bucket
    } else {
        Write-Host "[OK] Scoop bucket '$bucket' already added" -ForegroundColor Green
    }
}

# Install essential CLI tools via Scoop
# CLI + shell tools moved to mise: bat, fd, rg, delta, eza, gh, glow, jj, jq, lazygit, carapace, fzf, zoxide, neovim
$scoopPackages = @(
    'kanata',
    'Meslo-NF',
    'mise',
    '1password-cli'
)

# Get list of installed packages once
$installedPackages = scoop list 2>$null | ForEach-Object { $_.Name }

Write-Host "[Install] Installing essential CLI tools via Scoop..." -ForegroundColor Blue
$failedPackages = @()
foreach ($package in $scoopPackages) {
    if ($package -notin $installedPackages) {
        Write-Host "Installing $package..." -ForegroundColor Cyan
        scoop install $package
        if ($LASTEXITCODE -ne 0) {
            $failedPackages += $package
            Write-Host "[ERROR] Failed to install $package (exit $LASTEXITCODE)" -ForegroundColor Red
        }
    } else {
        Write-Host "[OK] $package already installed" -ForegroundColor Green
    }
}

if ($failedPackages.Count -gt 0) {
    Write-Host "[ERROR] Scoop install failures: $($failedPackages -join ', ')" -ForegroundColor Red
    exit 1
}

Write-Host "[OK] Scoop setup completed!" -ForegroundColor Green
{{- end }}