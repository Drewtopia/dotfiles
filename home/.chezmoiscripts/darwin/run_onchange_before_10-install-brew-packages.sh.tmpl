#!/bin/bash

set -eufo pipefail

{{/* CLI + shell tools moved to mise: bat, fd, rg, delta, eza, gh, glow, gdu, jq, jless, lazygit, age, golangci-lint, yt-dlp, atuin, carapace, fzf, zoxide */}}
{{ $brews := list
    "btop"
    "curl"
    "dockutil"
    "ffmpeg"
    "git"
    "git-lfs"
    "gnu-units"
    "gnupg"
    "kanata"
    "mas"
    "pkg-config"
    "shellcheck"
    "tmux"
    "wget"
    "xz" -}}
{{/* Excluded on purpose (do not auto-install): "logi-options+", "lunar" (one display manager only; betterdisplay is it), "raycast" (Raycast Beta is the one in use; it ships as a manual download, not a cask), "elgato-stream-deck" (hardware no longer used; ran a background process and a Sentry crash reporter) — re-add to the list below to restore. */}}
{{ $casks := list
	"1password@nightly"
    "1password-cli"
	"arc"
    "betterdisplay"
    "bruno"
    "chatgpt"
    "discord"
	"fmail3"
    "firefox@developer-edition"
    "font-fira-code"
    "font-fira-code-nerd-font"
    "font-fira-mono-nerd-font"
    "font-jetbrains-mono"
    "font-jetbrains-mono-nerd-font"
    "font-monaspace"
    "font-symbols-only-nerd-font"
    "ghostty"
    "git-credential-manager"
    "hammerspoon"
    "hazel"
    "home-assistant"
    "iina"
    "iterm2"
    "jdownloader"
    "jump-desktop-connect"
    "keka"
    "keyclu"
    "muzzle"
    "obsidian"
    "orion"
    "plex"
    "raindropio"
    "rectangle-pro"
    "setapp"
    "spotify"
    "soundsource"
    "glance-chamburr"
    "syntax-highlight"
    "tailscale-app"
    "telegram"
    "transmission"
    "unclack"
    "visual-studio-code"
    "wezterm"
    "zen"
    "qlmarkdown"
    "quicklook-video" -}}

echo "🍎 Installing system packages via Homebrew..."

brew bundle --file=/dev/stdin <<EOF
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF

# Remove quarantine flag from Quick Look plugins that need it
for cask in glance-chamburr qlmarkdown; do
    cask_dir="$(brew --caskroom)/$cask" 2>/dev/null
    if [[ -d "$cask_dir" ]]; then
        xattr -dr com.apple.quarantine "$cask_dir" 2>/dev/null || true
    fi
done

echo "✅ Homebrew packages installed!"
