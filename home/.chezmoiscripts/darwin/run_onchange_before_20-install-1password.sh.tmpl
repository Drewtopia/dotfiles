{{- if and (eq .chezmoi.os "darwin") (not .ephemeral) -}}
#!/usr/bin/env bash
# Install the 1Password CLI on macOS if not already present.
# Mirrors linux/run_onchange_before_20-install-1password.sh.tmpl.
#
# After this script runs, future `chezmoi init` invocations will use the
# `onepasswordRead` branch in chezmoi.toml.tmpl (instead of the fallback
# prompt path). The promptStringOnce-cached identity from the first init
# stays in place though — delete the name/email entries in
# ~/.config/chezmoi/chezmoi.toml and re-init to switch over.

set -euo pipefail

if command -v op >/dev/null 2>&1; then
    exit 0
fi

if ! command -v brew >/dev/null 2>&1; then
    echo "[bootstrap] op not found and brew not installed; skipping"
    echo "[bootstrap]   See https://developer.1password.com/docs/cli/get-started/"
    exit 0
fi

echo "[bootstrap] Installing 1Password CLI via Homebrew..."
brew install 1password-cli
echo "[bootstrap] op installed: $(op --version)"
echo "[bootstrap] Sign in to use it: enable desktop integration in 1Password app,"
echo "[bootstrap]   or run: eval \$(op signin)"
{{- end -}}
