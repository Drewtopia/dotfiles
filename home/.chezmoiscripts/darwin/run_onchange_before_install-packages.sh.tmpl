#!/bin/bash

set -eufo pipefail

{{/* CLI + shell tools moved to mise: bat, fd, rg, delta, eza, gh, glow, gdu, jq, jj, jless, lazygit, age, golangci-lint, yt-dlp, atuin, carapace, fzf, zoxide */}}
{{ $brews := list
    "btop"
    "curl"
    "dockutil"
    "ffmpeg"
    "git"
    "git-lfs"
    "gnu-units"
    "gnupg"
    "kanata"
    "mas"
    "pkg-config"
    "shellcheck"
    "tmux"
    "wget"
    "xz" -}}
{{ $casks := list
	"1password@nightly"
    "1password-cli"
	"arc"
    "betterdisplay"
    "bruno"
    "chatgpt"
    "discord"
    "elgato-stream-deck"
	"fmail3"
    "firefox@developer-edition"
    "font-fira-code"
    "font-fira-code-nerd-font"
    "font-fira-mono-nerd-font"
    "font-jetbrains-mono"
    "font-jetbrains-mono-nerd-font"
    "font-monaspace"
    "font-symbols-only-nerd-font"
    "ghostty"
    "hammerspoon"
    "hazel"
    "iina"
    "imageoptim"
    "iterm2"
    "jdownloader"
    "jordanbaird-ice"
    "jump-desktop-connect"
    "keka"
    "keycastr"
    "keyclu"
    "leader-key"
    "logi-options+"
    "lookaway"
    "lunar"
    "muzzle"
    "obsidian"
    "onyx"
    "orion"
    "plex"
    "raindropio"
    "raycast"
    "rectangle-pro"
    "setapp"
    "spotify"
    "soundsource"
    "glance-chamburr"
    "syntax-highlight"
    "tailscale-app"
    "telegram"
    "transmission"
    "unclack"
    "visual-studio-code"
    "vlc"
    "wezterm"
    "zen"
    "qlmarkdown"
    "quicklook-video" -}}

echo "🍎 Installing system packages via Homebrew..."

brew bundle --file=/dev/stdin <<EOF
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF

# Remove quarantine flag from Quick Look plugins that need it
for cask in glance-chamburr qlmarkdown; do
    cask_dir="$(brew --caskroom)/$cask" 2>/dev/null
    if [[ -d "$cask_dir" ]]; then
        xattr -dr com.apple.quarantine "$cask_dir" 2>/dev/null || true
    fi
done

{{ if .dev_computer -}}
# Install mise (runtime version manager) — installer auto-runs `mise install --yes`
# Subsequent installs triggered by 200-install-mise-tools when config.toml changes
echo "📦 Installing/updating mise..."
curl https://mise.run | sh || {
    echo "⚠️  Mise installation failed"
    exit 1
}
export PATH="$HOME/.local/bin:$PATH"
{{- end }}

echo "✅ macOS installation completed!"
