{{- if and (eq .osid "linux-ubuntu") (not .ephemeral) -}}
#!/bin/bash
set -euo pipefail

{{- if .is_wsl }}

# WSL2: Create wrapper to delegate to Windows op.exe
# The Windows 1Password app handles authentication via Windows Hello
WRAPPER="$HOME/.local/bin/op"
mkdir -p "$HOME/.local/bin"

# Find op.exe on the Windows side
OP_EXE=""
for candidate in \
    "/mnt/c/Program Files/1Password CLI/op.exe" \
    ; do
    if [[ -x "$candidate" ]]; then
        OP_EXE="$candidate"
        break
    fi
done

# Search WinGet packages and common install locations
if [[ -z "$OP_EXE" ]]; then
    OP_EXE=$(find "/mnt/c/Users" -maxdepth 8 -name "op.exe" -path "*1Password*" 2>/dev/null | head -1 || true)
fi

if [[ -z "$OP_EXE" ]]; then
    echo "⚠️  op.exe not found on Windows. Install with: winget install AgileBits.1PasswordCLI"
    exit 0
fi

echo "🔧 Creating op wrapper at $WRAPPER → $OP_EXE"
cat > "$WRAPPER" <<SCRIPT
#!/bin/bash
exec "$OP_EXE" "\$@"
SCRIPT
chmod +x "$WRAPPER"
echo "✅ 1Password CLI wrapper configured for WSL2"

{{- else }}

# Native Linux: Install 1Password CLI via apt
curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
	sudo gpg --dearmor --output /usr/share/keyrings/1password-archive-keyring.gpg

echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" |
	sudo tee /etc/apt/sources.list.d/1password.list

sudo mkdir -p /etc/debsig/policies/AC2D62742012EA22/
curl -sS https://downloads.1password.com/linux/debian/debsig/1password.pol | \
	sudo tee /etc/debsig/policies/AC2D62742012EA22/1password.pol
sudo mkdir -p /usr/share/debsig/keyrings/AC2D62742012EA22
curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
	sudo gpg --dearmor --output /usr/share/debsig/keyrings/AC2D62742012EA22/debsig.gpg

sudo apt update && sudo apt install -y 1password-cli

{{- end }}
{{ end -}}
