{{- if eq .osid "linux-debian" "linux-raspbian" "linux-ubuntu" -}}
{{- /* CLI + shell tools moved to mise: bat, fd, rg, gh, jq, age, fzf, zoxide, atuin, carapace */ -}}
{{- $packages := list
     "curl"
     "ffmpeg"
     "git"
     "git-lfs"
     "gnupg"
     "neovim"
     "pkg-config"
     "shellcheck"
     "tmux"
     "units"
     "unzip"
     "wget"
     "xz-utils"
     "zsh" -}}
{{- $snaps := list -}}
{{- $classicSnaps := list -}}
{{- if eq .osid "linux-ubuntu" -}}
{{-   $packages = mustAppend $packages "btop" -}}
{{- end -}}
{{- if not .ephemeral -}}
{{-   $packages = mustAppend $packages "xclip" -}}
{{-   if not .is_wsl -}}
{{-   $classicSnaps = mustAppend $classicSnaps "code" -}}
{{-   end -}}
{{- end -}}
{{- $sudo := "sudo " -}}
{{- if eq .chezmoi.username "root" -}}
{{-   $sudo = "" -}}
{{- end -}}
#!/bin/bash

set -eufo pipefail

echo "🐧 Installing system packages on Linux..."

{{ $sudo }}apt-get update
{{ $sudo }}apt-get install -y {{ $packages | join " " }}

{{ if and (lookPath "snap") (or $snaps $classicSnaps) }}
if [[ -S /run/snapd.socket ]]; then
{{   range $snaps }}
( snap info {{ . }} | grep -q ^installed: ) || {{ $sudo }}snap install {{ . }} || true
{{   end }}
{{   range $classicSnaps }}
( snap info {{ . }} | grep -q ^installed: ) || {{ $sudo }}snap install --classic {{ . }} || true
{{   end }}
fi
{{ end }}

echo "✅ apt packages installed!"

{{ end -}}
