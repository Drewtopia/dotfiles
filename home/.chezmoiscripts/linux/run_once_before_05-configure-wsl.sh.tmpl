{{- if .is_wsl -}}
#!/bin/bash
set -euo pipefail

# Passwordless sudo for WSL (local dev VM, not a shared server)
SUDOERS_FILE="/etc/sudoers.d/{{ .chezmoi.username }}"
if [[ ! -f "$SUDOERS_FILE" ]]; then
    echo "🔧 Configuring passwordless sudo..."
    echo "{{ .chezmoi.username }} ALL=(ALL) NOPASSWD:ALL" | sudo tee "$SUDOERS_FILE" > /dev/null
    sudo chmod 0440 "$SUDOERS_FILE"
    echo "✅ Passwordless sudo configured"
else
    echo "✅ Passwordless sudo already configured"
fi

# Configure WSL2: interop ON, appendWindowsPath ON
# mise Linux tools come first in PATH, Windows .exe binaries available as fallback
if [[ ! -f /etc/wsl.conf ]] || ! grep -q "appendWindowsPath" /etc/wsl.conf 2>/dev/null; then
    echo "🔧 Configuring /etc/wsl.conf..."
    sudo tee /etc/wsl.conf > /dev/null <<EOF
[interop]
enabled = true
appendWindowsPath = true

[automount]
enabled = true
options = "metadata,umask=22,fmask=11"

[user]
default = {{ .chezmoi.username }}
EOF
    echo "✅ WSL configured. Run 'wsl --shutdown' from Windows to apply."
else
    echo "✅ /etc/wsl.conf already configured"
fi
{{- end }}
