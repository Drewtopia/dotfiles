# Repo-specific ignores (common patterns in ~/.config/git/ignore)

# Installed Claude Code skills (regenerable from skills-lock.json — treat like node_modules)
.agents/

# Node toolchain for changesets (CHANGELOG generation only; nothing is published).
node_modules/

# GSD planning artifacts kept local (commit_docs=false in .planning/config.json).
# Note: .planning/codebase/*.md was committed before this entry was added and
# remains tracked. To start tracking the rest, remove this rule and `git add`.
.planning/

# Scratch files — including identity-redaction rule files. Must never be tracked
# on a public repo.
*.tmp

# Triage area for unsorted docs. Promote files out of here before committing them.
/docs/inbox/

# Defence in depth — never track these even if a template variant exists.
# (chezmoi's private_*.tmpl files are safe; these patterns catch raw local files
# that might land here by accident, e.g. a stray ~/.ssh copy.)
.env
.env.*
!.env.example
*.pem
*.key
id_rsa
id_ed25519
